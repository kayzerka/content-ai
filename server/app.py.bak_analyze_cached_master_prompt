        if not video_id:
            continue

        snippet = v.get("snippet", {})
        statistics = v.get("statistics", {})

        title = snippet.get("title", "")
        description = snippet.get("description", "")
        published_at = snippet.get("publishedAt") or datetime.now().isoformat(timespec="seconds")
        url = f"https://www.youtube.com/watch?v={video_id}"

        views = int(statistics.get("viewCount", 0) or 0)
        likes = int(statistics.get("likeCount", 0) or 0)
        comments = int(statistics.get("commentCount", 0) or 0)

        existing_post = cur.execute("""
            SELECT id
            FROM posts
            WHERE platform='YouTube'
              AND url=?
            LIMIT 1
        """, (url,)).fetchone()

        cur.execute("""
            INSERT INTO post_metrics (
                collected_at, platform, external_post_id, external_url,
                title, views, likes, comments, raw_json
            )
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
        """, (
            datetime.now().isoformat(timespec="seconds"),
            "youtube",
            video_id,
            url,
            title,
            views,
            likes,
            comments,
            str(v),
        ))
        saved_metrics += 1

        if existing_post:
            cur.execute("""
                UPDATE posts
                SET created_at=?,
                    views=?,
                    likes=?,
                    comments=?,
                    score=?,
                    analysis=CASE
                        WHEN analysis IS NULL OR analysis='' OR analysis LIKE 'Imported from YouTube API%'
                        THEN ?
                        ELSE analysis
                    END
                WHERE id=?
            """, (
                published_at,
                views,
                likes,
                comments,
                calc_score(views, likes, comments, 0, 0),
                "Imported from YouTube API. Updated by safe sync.",
                existing_post["id"],
            ))
            skipped_posts += 1
        else:
            cur.execute("""
                INSERT INTO posts (
                    created_at, platform, url, text,
                    views, likes, comments, saves, shares,
                    analysis, score
                )
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
            """, (
                datetime.now().isoformat(timespec="seconds"),
                "YouTube",
                url,
                f"{title}\n\n{description}".strip(),
                views,
                likes,
                comments,
                0,
                0,
                "Imported from YouTube API. AI analysis not generated yet.",
                calc_score(views, likes, comments, 0, 0),
            ))
            saved_posts += 1

    con.commit()
    con.close()

    return {
        "status": "ok",
        "saved_posts": saved_posts,
        "updated_existing_posts": skipped_posts,
        "saved_metrics_snapshots": saved_metrics,
    }


