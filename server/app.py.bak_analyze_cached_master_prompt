@app.post("/analyze_cached")
async def analyze_cached(request: Request):
    payload = await request.json()

    platform = str(payload.get("platform") or "").strip()
    external_id = str(payload.get("external_id") or payload.get("post_id") or "").strip()
    url = str(payload.get("url") or "").strip()

    text = (
        payload.get("text")
        or payload.get("content")
        or payload.get("caption")
        or payload.get("title")
        or ""
    )
    text = str(text).strip()

    if not text:
        return {
            "status": "error",
            "error": "empty_text",
            "message": "Немає тексту для AI аналізу"
        }

    text_hash = hashlib.sha256(text.encode("utf-8")).hexdigest()

    con = sqlite3.connect(DB_PATH)
    con.row_factory = sqlite3.Row
    cur = con.cursor()

    cached = cur.execute("""
        SELECT analysis
        FROM ai_analysis_cache
        WHERE platform=?
          AND external_id=?
          AND text_hash=?
        LIMIT 1
    """, (platform, external_id, text_hash)).fetchone()

    if cached and cached["analysis"]:
        con.close()
        return {
            "status": "ok",
            "cached": True,
            "result": cached["analysis"],
            "analysis": cached["analysis"]
        }

    prompt = f"""
Проаналізуй контент для експерта-регресолога/кармолога.

Платформа: {platform}
Посилання: {url}

Контент:
{text}

Дай відповідь українською структуровано:
1. AI оцінка від 1 до 100
2. Що добре
3. Що змінити
4. Сила хуку
5. Рекомендований час публікації
6. Ідея для наступного ролика
7. Головна рекомендація
"""

    analysis = run_llm(prompt)

    if not analysis or not analysis.strip():
        con.close()
        return {
            "status": "error",
            "error": "empty_ai_response",
            "message": "AI не повернув відповідь"
        }

    now = datetime.now().isoformat(timespec="seconds")

    cur.execute("""
        INSERT OR REPLACE INTO ai_analysis_cache (
            created_at,
            updated_at,
            platform,
            external_id,
            url,
            text_hash,
            input_text,
            analysis
        )
        VALUES (
            COALESCE(
                (SELECT created_at FROM ai_analysis_cache WHERE platform=? AND external_id=? AND text_hash=?),
                ?
            ),
            ?, ?, ?, ?, ?, ?, ?
        )
    """, (
        platform, external_id, text_hash,
        now,
        now,
        platform,
        external_id,
        url,
        text_hash,
        text,
        analysis
    ))

    con.commit()
    con.close()

    return {
        "status": "ok",
        "cached": False,
        "result": analysis,
        "analysis": analysis
    }

