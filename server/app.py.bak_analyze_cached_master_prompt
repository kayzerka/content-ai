            "draft",
        ))

        created.append({
            "platform_version_id": cur.lastrowid,
            "platform": platform,
        })

    con.commit()
    con.close()

    return {
        "status": "ok",
        "content_id": content_id,
        "created": created,
        "parsed": parsed,
    }


