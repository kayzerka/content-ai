    con = sqlite3.connect(DB_PATH)
    con.row_factory = sqlite3.Row
    cur = con.cursor()

    item = cur.execute("""
        SELECT *
        FROM content_items
        WHERE id=?
    """, (content_id,)).fetchone()

    if not item:
        con.close()
        return {"status": "error", "error": "content_id not found"}

    platform_list = [p.strip() for p in platforms.split(",") if p.strip()]

    prompt = f"""
Ти AI-контент директор.

Є базовий контент:

TITLE:
{item["title"]}

BASE_CAPTION:
{item["base_caption"]}

VIDEO_PATH:
{item["video_path"]}

Потрібно адаптувати контент окремо під ці платформи:
{platform_list}

Поверни ТІЛЬКИ валідний JSON без markdown, без пояснень.

Формат строго такий:

{{
  "Instagram": {{
    "caption": "...",
    "hook": "...",
    "hashtags": "...",
    "cta": "...",
    "location": "...",
    "privacy_status": "public",
    "dont_write": "..."
  }},
    "YouTube": {{
    "caption": "...",
    "hook": "...",
    "hashtags": "...",
    "cta": "...",
    "location": "",
    "privacy_status": "private",
    "dont_write": "..."
  }},
  "Facebook": {{
    "caption": "...",
    "hook": "...",
    "hashtags": "...",
    "cta": "...",
    "location": "...",
    "privacy_status": "public",
    "dont_write": "..."
  }}
}}

Правила:
- Instagram: сильний перший рядок, емоція, збереження, коментар.
- Facebook: коротше, провокативніше, перші 3 секунди, мінімум довгого тексту.
- YouTube Shorts: SEO-заголовок у caption, #shorts, підписка.
- Facebook: тепліше, більше контексту, можна довше.
- Якщо контент тестовий, все одно зроби коротку робочу адаптацію без довгих пояснень.
"""

    ai_text = run_llm(prompt)
    parsed = _extract_json_object(ai_text)

    if not parsed:
        con.close()
        return {
            "status": "error",
            "error": "AI did not return valid JSON",
            "raw": ai_text,
        }

    created = []

    for platform in platform_list:
        data = parsed.get(platform) or parsed.get(platform.lower()) or {}

        caption_parts = [
            data.get("hook", "").strip(),
            data.get("caption", "").strip(),
            data.get("cta", "").strip(),
            data.get("dont_write", "").strip(),
        ]

        caption = "\n\n".join([x for x in caption_parts if x])

        cur.execute("""
            INSERT INTO platform_versions (
                created_at,
                content_id,
                platform,
                caption,
                hashtags,
                location,
