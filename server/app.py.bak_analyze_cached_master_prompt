        media = MediaFileUpload(
            video_path,
            chunksize=-1,
            resumable=True,
        )

        request = youtube.videos().insert(
            part="snippet,status",
            body=body,
            media_body=media,
        )

        response = None
        last_progress = 0

        while response is None:
            status, response = request.next_chunk()
            if status:
                last_progress = int(status.progress() * 100)

        video_id = response.get("id", "")
        external_url = f"https://www.youtube.com/watch?v={video_id}" if video_id else ""

        cur.execute("""
            UPDATE platform_versions
            SET publish_status=?,
                external_post_id=?,
                external_url=?,
                error=?
            WHERE id=?
        """, (
            "published" if video_id else "uploaded_unknown",
            video_id,
            external_url,
            "",
            platform_version_id,
        ))

        cur.execute("""
            INSERT INTO posts (
                created_at, platform, url, text,
                views, likes, comments, saves, shares,
                analysis, score
            )
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """, (
            datetime.now().isoformat(timespec="seconds"),
            "YouTube",
            external_url,
            title + "\n\n" + description,
            0,
            0,
            0,
            0,
            0,
            "Uploaded via Platform Hub YouTube OAuth.",
            0,
        ))

        con.commit()
        con.close()

        return {
            "status": "ok",
            "platform_version_id": platform_version_id,
            "youtube_video_id": video_id,
            "url": external_url,
            "privacy_status": privacy_status,
            "progress": last_progress,
            "raw": response,
        }

    except Exception as e:
        cur.execute("""
            UPDATE platform_versions
