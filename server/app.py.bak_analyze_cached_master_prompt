def extract_audio_from_video(video_path: str) -> str:
    out_path = tempfile.mktemp(suffix=".wav")
    cmd = [
        os.getenv("FFMPEG_BIN", "ffmpeg"), "-y", "-i", video_path,
        "-vn", "-acodec", "pcm_s16le",
        "-ar", "16000", "-ac", "1", out_path,
    ]
    subprocess.run(cmd, check=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    return out_path


def download_video_to_tmp(video_url: str) -> str:
    tmp_path = tempfile.mktemp(suffix=".mp4")

    headers = {}
    api_token = os.getenv("VIDEO_API_TOKEN", "").strip()
    if api_token:
        headers["Authorization"] = f"Bearer {api_token}"

    with requests.get(video_url, headers=headers, stream=True, timeout=120) as r:
        r.raise_for_status()
        with open(tmp_path, "wb") as f:
            for chunk in r.iter_content(chunk_size=1024 * 1024):
                if chunk:
                    f.write(chunk)

    return tmp_path


def resolve_video_source(video_path: str = "", video_url: str = "") -> tuple[str, bool]:
    """
    Returns: (local_video_path, should_cleanup)
    """
    video_path = (video_path or "").strip()
    video_url = (video_url or "").strip()

    if video_path:
        src = Path(video_path)

        if not src.exists():
            raise FileNotFoundError(f"video file not found: {video_path}")

        # If path is already ASCII-safe, pass it directly to ffmpeg.
        try:
            video_path.encode("ascii")
            return video_path, False
        except UnicodeEncodeError:
            pass

        # Old macOS / subprocess can fail on Cyrillic paths.
        # Copy to ASCII temp path instead of symlink to avoid symlink loops.
        safe_dir = Path(__file__).resolve().parent / "_tmp_video_sources"
        safe_dir.mkdir(exist_ok=True)

        suffix = src.suffix if src.suffix else ".mp4"
        safe_path = safe_dir / f"input_video_copy{suffix}"

        import shutil
        if safe_path.exists() or safe_path.is_symlink():
            safe_path.unlink()

        shutil.copy2(str(src), str(safe_path))
        return str(safe_path), True

    if video_url:
        local_tmp = download_video_to_tmp(video_url)
        return local_tmp, True

    raise ValueError("empty video_path and empty video_url")


def transcribe_video(video_path: str = "", video_url: str = "") -> str:
    local_video_path, cleanup_video = resolve_video_source(video_path, video_url)
    audio_path = extract_audio_from_video(local_video_path)

    try:
        from openai import OpenAI
        client = OpenAI(api_key=os.getenv("OPENAI_API_KEY"))

        with open(audio_path, "rb") as audio_file:
            resp = client.audio.transcriptions.create(
                model=os.getenv("OPENAI_TRANSCRIBE_MODEL", "gpt-4o-mini-transcribe"),
                file=audio_file,
            )

        return getattr(resp, "text", "").strip()

    finally:
        try:
            os.remove(audio_path)
        except Exception:
            pass

        if cleanup_video:
            try:
                os.remove(local_video_path)
            except Exception:
                pass


