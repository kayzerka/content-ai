        SELECT *
        FROM content_items
        WHERE id=?
    """, (pv["content_id"],)).fetchone()

    if not item:
        con.close()
        return {"status": "error", "error": "content item not found"}

    video_path = (item["video_path"] or "").strip()

    if not video_path:
        con.close()
        return {
            "status": "error",
            "error": "content_items.video_path is empty",
        }

    if not Path(video_path).exists():
        con.close()
        return {
            "status": "error",
            "error": f"video file not found: {video_path}",
        }

    title = (item["title"] or "").strip() or "Uploaded video"
    description = (pv["caption"] or "").strip()

    hashtags = (pv["hashtags"] or "").strip()
    if hashtags and hashtags not in description:
        description = (description + "\n\n" + hashtags).strip()

    privacy_status = (pv["privacy_status"] or "private").strip().lower()
    if privacy_status not in ("private", "unlisted", "public"):
        privacy_status = "private"

    body = {
