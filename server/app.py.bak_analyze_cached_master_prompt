@app.post("/analyze")
async def analyze(request: Request):
    text = ""
    video_path = ""
    video_url = ""

    text = request.query_params.get("text", "") or ""
    video_path = request.query_params.get("video_path", "") or ""
    video_url = request.query_params.get("video_url", "") or ""

    try:
        content_type = request.headers.get("content-type", "")

        if "application/json" in content_type:
            data = await request.json()
            text = data.get("text", text) or text
            video_path = data.get("video_path", video_path) or video_path
            video_url = data.get("video_url", video_url) or video_url
        else:
            raw = await request.body()
            parsed = parse_qs(raw.decode("utf-8", errors="ignore"))
            text = (parsed.get("text", [text])[0] or text)
            video_path = (parsed.get("video_path", [video_path])[0] or video_path)
            video_url = (parsed.get("video_url", [video_url])[0] or video_url)
    except Exception as e:
        return {
            "status": "error",
            "error": f"request parse failed: {str(e)}",
            "result": "",
        }

    transcript = ""

    if video_path or video_url:
        try:
            transcript = transcribe_video(video_path=video_path, video_url=video_url)
        except Exception as e:
            return {
                "status": "error",
                "error": f"transcription failed: {str(e)}",
                "traceback": traceback.format_exc(),
                "result": "",
            }

    if not text.strip() and not transcript.strip():
        return {
            "status": "error",
            "error": "empty text and empty transcript",
            "result": "",
        }

    prompt = build_content_analysis_prompt(
        text=text,
        video_path=video_path or video_url,
        transcript=transcript,
    )

    return {
        "status": "ok",
        "result": run_llm(prompt),
        "transcript": transcript,
        "video_path": video_path,
        "video_url": video_url,
    }
