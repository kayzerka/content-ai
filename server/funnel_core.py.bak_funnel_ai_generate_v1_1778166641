def run_contact_next_step(funnel_id: int, platform: str, external_user_id: str):
    init_funnel_db()

    contact = get_contact_by_external(funnel_id, platform, external_user_id)
    if not contact:
        return {
            "ok": False,
            "error": "contact_not_found",
            "hint": "First send /api/funnels/event for this user"
        }

    step_order = int(contact.get("current_step") or 1)
    step = get_step(funnel_id, step_order)

    if not step:
        return {
            "ok": True,
            "done": True,
            "contact": contact,
            "message": "No more steps"
        }

    result = execute_step(contact, step)

    return {
        "ok": result.get("ok", False),
        "done": False,
        "contact": contact,
        "step": step,
        "result": result,
    }

def funnel_contact_debug(funnel_id: int, platform: str, external_user_id: str):
    init_funnel_db()
    con = db()

    contact = con.execute("""
        SELECT * FROM funnel_contacts
        WHERE funnel_id=? AND platform=? AND external_user_id=?
    """, (funnel_id, platform, external_user_id)).fetchone()

    if not contact:
        con.close()
        return {"ok": False, "error": "contact_not_found"}

    contact = row_to_dict(contact)

    events = con.execute("""
        SELECT * FROM funnel_events
        WHERE contact_id=?
        ORDER BY id DESC
        LIMIT 30
    """, (contact["id"],)).fetchall()

    jobs = con.execute("""
        SELECT * FROM funnel_jobs
        WHERE contact_id=?
        ORDER BY id DESC
        LIMIT 30
    """, (contact["id"],)).fetchall()

    con.close()

    return {
        "ok": True,
        "contact": contact,
        "events": [row_to_dict(x) for x in events],
        "jobs": [row_to_dict(x) for x in jobs],
    }

def list_telegram_destinations():
    """
    Best-effort discovery of Telegram assets from existing project DB.
    Does not assume exact schema; checks common table names.
    """
    init_funnel_db()
    con = db()
    cur = con.cursor()

    tables = [r["name"] for r in cur.execute("""
        SELECT name FROM sqlite_master
        WHERE type='table'
    """).fetchall()]

    candidates = []
    possible = [
        "telegram_chats",
        "telegram_groups",
        "telegram_channels",
        "tg_chats",
        "tg_groups",
        "connected_telegram_chats",
    ]

    for t in possible:
        if t not in tables:
            continue

        try:
            cols = [c["name"] for c in cur.execute(f"PRAGMA table_info({t})").fetchall()]
            rows = cur.execute(f"SELECT * FROM {t} LIMIT 100").fetchall()

            for r in rows:
                d = row_to_dict(r)
                title = (
                    d.get("title")
                    or d.get("name")
                    or d.get("chat_title")
                    or d.get("username")
                    or str(d.get("chat_id") or d.get("id") or "")
                )
                chat_id = (
                    d.get("chat_id")
                    or d.get("telegram_chat_id")
                    or d.get("external_id")
                    or d.get("id")
                )

                candidates.append({
                    "source_table": t,
                    "title": title,
                    "chat_id": chat_id,
                    "username": d.get("username") or d.get("handle") or "",
                    "type": d.get("type") or d.get("chat_type") or "",
                    "raw": d,
                })
        except Exception as e:
            candidates.append({
                "source_table": t,
                "error": str(e),
            })

    con.close()

    return {
        "ok": True,
        "items": candidates,
        "tables_checked": possible,
        "tables_found": [x for x in possible if x in tables],
    }
