
(function(){
  const ID = "funnels-mvp-panel";

  async function api(path, opts){
    const r = await fetch(path, opts || {});
    return await r.json();
  }

  function esc(s){
    return String(s == null ? "" : s)
      .replace(/&/g,"&amp;")
      .replace(/</g,"&lt;")
      .replace(/>/g,"&gt;");
  }

  function css(){
    if (document.getElementById("funnels-mvp-style")) return;
    const st = document.createElement("style");
    st.id = "funnels-mvp-style";
    st.textContent = `
      #funnels-mvp-btn{
        position:fixed;right:18px;bottom:82px;z-index:9999;
        border:0;border-radius:999px;padding:12px 16px;
        background:#111;color:#fff;box-shadow:0 10px 30px rgba(0,0,0,.22);
        cursor:pointer;font-weight:700;
      }
      #funnels-mvp-panel{
        position:fixed;right:18px;bottom:138px;width:420px;max-width:calc(100vw - 36px);
        max-height:72vh;overflow:auto;z-index:9999;background:#fff;color:#111;
        border:1px solid #ddd;border-radius:18px;box-shadow:0 20px 60px rgba(0,0,0,.28);
        padding:16px;font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
      }
      #funnels-mvp-panel h3{margin:0 0 10px;font-size:18px}
      #funnels-mvp-panel .row{display:flex;gap:8px;flex-wrap:wrap;margin:8px 0}
      #funnels-mvp-panel button{
        border:1px solid #ddd;border-radius:10px;background:#f7f7f7;padding:8px 10px;cursor:pointer;
      }
      #funnels-mvp-panel input{
        width:100%;box-sizing:border-box;border:1px solid #ddd;border-radius:10px;padding:9px;margin:6px 0;
      }
      #funnels-mvp-panel pre{
        white-space:pre-wrap;background:#f6f6f6;border-radius:12px;padding:10px;font-size:12px;
      }
      #funnels-mvp-panel .card{border:1px solid #eee;border-radius:14px;padding:10px;margin:8px 0;background:#fafafa}
      #funnels-mvp-panel .muted{color:#666;font-size:12px}
    `;
    document.head.appendChild(st);
  }

  async function render(){
    css();

    let panel = document.getElementById(ID);
    if (!panel) {
      panel = document.createElement("div");
      panel.id = ID;
      document.body.appendChild(panel);
    }

    panel.innerHTML = `
      <h3>🧲 Funnel Builder MVP</h3>
      <div class="muted">Instagram / Telegram funnel core</div>

      <div class="row">
        <button data-act="init">Init DB</button>
        <button data-act="create">Create default funnel</button>
        <button data-act="load">Reload</button>
        <button data-act="jobs">Run due jobs</button>
        <button data-act="tg">TG destinations</button>
        <button data-act="next">Run next step</button>
      </div>

      <div>
        <input id="funnel-test-id" placeholder="funnel_id для тесту">
        <input id="funnel-test-user" placeholder="external_user_id" value="test_user_1">
        <input id="funnel-test-event" placeholder="event_type" value="comment_keyword">
        <button data-act="event">Test funnel event</button>
      </div>

      <div id="funnels-mvp-output">Loading...</div>
    `;

    panel.querySelectorAll("button[data-act]").forEach(btn => {
      btn.onclick = async () => {
        const act = btn.getAttribute("data-act");
        const out = panel.querySelector("#funnels-mvp-output");

        try {
          if (act === "init") {
            out.innerHTML = "<pre>" + esc(JSON.stringify(await api("/api/funnels/init", {method:"POST"}), null, 2)) + "</pre>";
          }

          if (act === "create") {
            const res = await api("/api/funnels/default", {
              method:"POST",
              headers: {"Content-Type":"application/json"},
              body: JSON.stringify({name:"Instagram → Telegram → Consultation"})
            });
            out.innerHTML = "<pre>" + esc(JSON.stringify(res, null, 2)) + "</pre>";
          }

          if (act === "load") {
            await loadList(out);
          }

          if (act === "jobs") {
            out.innerHTML = "<pre>" + esc(JSON.stringify(await api("/api/funnels/jobs/run-due", {method:"POST"}), null, 2)) + "</pre>";
          }


          if (act === "tg") {
            out.innerHTML = "<pre>" + esc(JSON.stringify(await api("/api/funnels/telegram/destinations"), null, 2)) + "</pre>";
          }

          if (act === "next") {
            const fid = Number(panel.querySelector("#funnel-test-id").value || 1);
            const uid = panel.querySelector("#funnel-test-user").value || "test_user_1";

            const res = await api("/api/funnels/contact/run-next", {
              method:"POST",
              headers: {"Content-Type":"application/json"},
              body: JSON.stringify({
                funnel_id: fid,
                platform: "instagram",
                external_user_id: uid
              })
            });

            out.innerHTML = "<pre>" + esc(JSON.stringify(res, null, 2)) + "</pre>";
          }


          if (act === "event") {
            const fid = Number(panel.querySelector("#funnel-test-id").value || 1);
            const uid = panel.querySelector("#funnel-test-user").value || "test_user_1";
            const ev = panel.querySelector("#funnel-test-event").value || "manual";

            const res = await api("/api/funnels/event", {
              method:"POST",
              headers: {"Content-Type":"application/json"},
              body: JSON.stringify({
                funnel_id: fid,
                platform: "instagram",
                external_user_id: uid,
                username: uid,
                event_type: ev,
                payload: {keyword:"ПРИЧИНА", source:"frontend_test"}
              })
            });

            out.innerHTML = "<pre>" + esc(JSON.stringify(res, null, 2)) + "</pre>";
          }
        } catch(e) {
          out.innerHTML = "<pre>ERROR: " + esc(e.message || e) + "</pre>";
        }
      };
    });

    await loadList(panel.querySelector("#funnels-mvp-output"));
  }

  async function loadList(out){
    const [list, stats] = await Promise.all([
      api("/api/funnels"),
      api("/api/funnels/analytics/summary")
    ]);

    const items = (list.items || []).map(f => `
      <div class="card">
        <b>#${esc(f.id)} ${esc(f.name)}</b>
        <div class="muted">${esc(f.source_platform)} / ${esc(f.source_type)} → ${esc(f.goal)}</div>
        <div>trigger: <b>${esc(f.trigger_type)}</b> = ${esc(f.trigger_value)}</div>
        <div>output: ${esc(f.output_type)} ${esc(f.output_target || "")}</div>
      </div>
    `).join("");

    out.innerHTML = `
      <h4>Funnels</h4>
      ${items || '<div class="muted">No funnels yet. Click “Create default funnel”.</div>'}
      <h4>Analytics</h4>
      <pre>${esc(JSON.stringify(stats.items || [], null, 2))}</pre>
    `;
  }

  function boot(){
    css();

    if (!document.getElementById("funnels-mvp-btn")) {
      const btn = document.createElement("button");
      btn.id = "funnels-mvp-btn";
      btn.textContent = "Funnels";
      btn.onclick = () => {
        const p = document.getElementById(ID);
        if (p) p.remove();
        else render();
      };
      document.body.appendChild(btn);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot);
  } else {
    boot();
  }

  window.openFunnelsMvp = render;
})();
