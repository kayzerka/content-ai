(function InstagramTelegramSettingsToggleV1() {
  if (window.__instagramTelegramSettingsToggleV1) return;
  window.__instagramTelegramSettingsToggleV1 = true;

  function findSettingsModal() {
    return Array.from(document.querySelectorAll("div")).find(el => {
      const txt = el.innerText || "";
      return txt.includes("Instagram Reaction Engine") &&
             txt.includes("Головна ціль воронки") &&
             txt.includes("Основний м");
    });
  }

  function injectToggle() {
    const modal = findSettingsModal();
    if (!modal) return;

    if (document.getElementById("ig-tg-settings-toggle-v1")) return;

    const title = Array.from(modal.querySelectorAll("h1,h2,h3"))
      .find(el => (el.innerText || "").includes("Instagram Reaction Engine"));

    const toggle = document.createElement("div");
    toggle.id = "ig-tg-settings-toggle-v1";
    toggle.style.display = "flex";
    toggle.style.gap = "8px";
    toggle.style.margin = "12px 0 16px";

    toggle.innerHTML = `
      <button type="button" id="ig-settings-tab-btn"
        style="padding:9px 14px;border-radius:10px;border:1px solid #111827;background:#111827;color:white;font-weight:900;">
        📸 Instagram
      </button>
      <button type="button" id="tg-settings-tab-btn"
        style="padding:9px 14px;border-radius:10px;border:1px solid #d1d5db;background:white;color:#111827;font-weight:900;">
        🤖 Telegram
      </button>
    `;

    const telegramForm = document.createElement("div");
    telegramForm.id = "telegram-settings-form-v1";
    telegramForm.style.display = "none";
    telegramForm.style.padding = "12px";
    telegramForm.style.border = "1px solid #dbe4ee";
    telegramForm.style.borderRadius = "12px";
    telegramForm.style.background = "#f8fafc";
    telegramForm.style.marginBottom = "16px";

    telegramForm.innerHTML = `
      <div style="font-size:18px;font-weight:900;margin-bottom:12px;">
        🤖 Telegram CTA налаштування
      </div>

      <label style="display:block;font-weight:800;margin-bottom:6px;">Telegram головна ціль</label>
      <textarea id="telegram-ai-goal" style="width:100%;min-height:70px;padding:10px;border:1px solid #d1d5db;border-radius:10px;">мʼяко перевести людину в direct і зрозуміти її запит</textarea>

      <label style="display:block;font-weight:800;margin:12px 0 6px;">Telegram основний CTA</label>
      <textarea id="telegram-main-cta" style="width:100%;min-height:70px;padding:10px;border:1px solid #d1d5db;border-radius:10px;">Напиши мені в direct — я підкажу, з чого почати.</textarea>

      <label style="display:block;font-weight:800;margin:12px 0 6px;">Telegram CTA для холодного користувача</label>
      <textarea id="telegram-cold-cta" style="width:100%;min-height:70px;padding:10px;border:1px solid #d1d5db;border-radius:10px;">Можеш просто написати в direct слово ПРИЧИНА — без зобовʼязань.</textarea>

      <label style="display:block;font-weight:800;margin:12px 0 6px;">Telegram CTA для теплого користувача</label>
      <textarea id="telegram-warm-cta" style="width:100%;min-height:70px;padding:10px;border:1px solid #d1d5db;border-radius:10px;">Якщо відгукується — напиши мені, розберемо твій запит.</textarea>

      <label style="display:block;font-weight:800;margin:12px 0 6px;">Telegram CTA для гарячого користувача</label>
      <textarea id="telegram-hot-cta" style="width:100%;min-height:70px;padding:10px;border:1px solid #d1d5db;border-radius:10px;">Напиши слово СЕСІЯ — я підкажу найближчий крок.</textarea>

      <label style="display:block;font-weight:800;margin:12px 0 6px;">Telegram офер / куди ведемо</label>
      <input id="telegram-offer-target" style="width:100%;padding:10px;border:1px solid #d1d5db;border-radius:10px;" value="діагностика запиту / консультація / сесія регресії / курс">

      <label style="display:block;font-weight:800;margin:12px 0 6px;">Telegram ключові слова ліда</label>
      <input id="telegram-lead-keywords" style="width:100%;padding:10px;border:1px solid #d1d5db;border-radius:10px;" value="ПРИЧИНА, СЕСІЯ, РЕГРЕСІЯ, ХОЧУ, КОНСУЛЬТАЦІЯ">
    `;

    if (title) {
      title.insertAdjacentElement("afterend", toggle);
      toggle.insertAdjacentElement("afterend", telegramForm);
    } else {
      modal.prepend(telegramForm);
      modal.prepend(toggle);
    }

    const igBtn = document.getElementById("ig-settings-tab-btn");
    const tgBtn = document.getElementById("tg-settings-tab-btn");

    function setMode(mode) {
      const tg = mode === "telegram";
      telegramForm.style.display = tg ? "block" : "none";

      igBtn.style.background = tg ? "white" : "#111827";
      igBtn.style.color = tg ? "#111827" : "white";

      tgBtn.style.background = tg ? "#111827" : "white";
      tgBtn.style.color = tg ? "white" : "#111827";

      window.aiSettingsPlatformMode = mode;
      console.log("[settings mode]", mode);
    }

    igBtn.onclick = () => setMode("instagram");
    tgBtn.onclick = () => setMode("telegram");

    setMode("instagram");
  }

  document.addEventListener("DOMContentLoaded", () => setTimeout(injectToggle, 1000));
  document.addEventListener("click", () => setTimeout(injectToggle, 300));

  window.injectInstagramTelegramSettingsToggle = injectToggle;
})();

