from pathlib import Path

try:
    from googleapiclient.discovery import build as google_build
    from googleapiclient.http import MediaFileUpload
    from google.oauth2.credentials import Credentials
    from google_auth_oauthlib.flow import InstalledAppFlow
    from google.auth.transport.requests import Request as GoogleAuthRequest
except Exception:
    google_build = None
    MediaFileUpload = None
    Credentials = None
    InstalledAppFlow = None
    GoogleAuthRequest = None


YOUTUBE_UPLOAD_SCOPES = [
    "https://www.googleapis.com/auth/youtube.upload",
    "https://www.googleapis.com/auth/youtube.readonly",
]


def _youtube_oauth_paths():
    client_file = os.getenv("YOUTUBE_CLIENT_SECRETS_FILE", "./client_secret.json").strip()
    token_file = os.getenv("YOUTUBE_TOKEN_FILE", "./youtube_token.json").strip()
    return client_file, token_file


def _youtube_oauth_ready():
    client_file, token_file = _youtube_oauth_paths()
    return {
        "google_libs_ok": bool(google_build and MediaFileUpload and Credentials and InstalledAppFlow and GoogleAuthRequest),
        "client_secret_file": client_file,
        "client_secret_exists": Path(client_file).exists(),
        "token_file": token_file,
        "token_exists": Path(token_file).exists(),
        "scopes": YOUTUBE_UPLOAD_SCOPES,
    }


def get_youtube_oauth_credentials(force_reauth: bool = False):
    if not all([google_build, MediaFileUpload, Credentials, InstalledAppFlow, GoogleAuthRequest]):
        raise RuntimeError("Google OAuth libraries are not installed. Run: pip install google-api-python-client google-auth google-auth-oauthlib google-auth-httplib2")

    client_file, token_file = _youtube_oauth_paths()

    if not Path(client_file).exists():
        raise RuntimeError(f"OAuth client secret file not found: {client_file}")

    creds = None

    if Path(token_file).exists() and not force_reauth:
        try:
            creds = Credentials.from_authorized_user_file(token_file, YOUTUBE_UPLOAD_SCOPES)
        except Exception:
            creds = None

    if creds and creds.expired and creds.refresh_token:
        creds.refresh(GoogleAuthRequest())

    if not creds or not creds.valid or force_reauth:
        flow = InstalledAppFlow.from_client_secrets_file(client_file, YOUTUBE_UPLOAD_SCOPES)
        creds = flow.run_local_server(
            port=8080,
            prompt="consent",
            access_type="offline",
        )

        with open(token_file, "w") as f:
            f.write(creds.to_json())

    return creds


def get_youtube_oauth_client(force_reauth: bool = False):
    creds = get_youtube_oauth_credentials(force_reauth=force_reauth)
    return google_build("youtube", "v3", credentials=creds)


