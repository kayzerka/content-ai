@app.post("/ai/content-score-video")
async def ai_content_score_video(
    platform: str = Form(""),
    external_id: str = Form(""),
    source_url: str = Form(""),
    title: str = Form(""),
    text: str = Form(""),
    video_path: str = Form(""),
    video_url: str = Form(""),
    views: int = Form(0),
    likes: int = Form(0),
    comments: int = Form(0),
    saves: int = Form(0),
    shares: int = Form(0),
    file: UploadFile | None = File(None),
):
    """
    Джерела:
    1) multipart file upload
    2) server-side video_path
    3) video_url
    """
    tmp_path = ""

    try:
        source_label = source_url or video_path or video_url or ""

        frame_analysis = {}

        if file is not None and file.filename:
            suffix = Path(file.filename).suffix or ".mp4"
            tmp_path = tempfile.mktemp(suffix=suffix)

            with open(tmp_path, "wb") as f:
                f.write(await file.read())

            source_label = file.filename
            transcript = transcribe_video(video_path=tmp_path)
            frame_analysis = analyze_video_frames(tmp_path)
        elif video_path or video_url:
            local_video_for_frames, cleanup_frames_video = resolve_video_source(video_path, video_url)
            try:
                transcript = transcribe_video(video_path=local_video_for_frames)
                frame_analysis = analyze_video_frames(local_video_for_frames)
            finally:
                if cleanup_frames_video:
                    try:
                        os.remove(local_video_for_frames)
                    except Exception:
                        pass
        else:
            transcript = ""
            frame_analysis = {}

        merged_text = "\n\n".join([
            x for x in [
                title.strip(),
                text.strip(),
                transcript.strip()
            ] if x
        ]).strip()

        if not merged_text:
            return {
                "status": "error",
                "error": "empty_text_and_transcript",
                "message": "Немає тексту, caption або транскрипту для аналізу."
            }

        rule = _content_quality_rule_score(
            merged_text,
            platform=platform,
            metrics={
                "views": views,
                "likes": likes,
                "comments": comments,
                "saves": saves,
                "shares": shares,
            }
        )

        # Blend transcript/text score with visual frame metrics + platform weights
        rule = blend_text_visual_scores(
            rule=rule,
            frame_analysis=frame_analysis,
            platform=platform,
        )

        visual_block = build_visual_frame_prompt_block(frame_analysis)

        prompt = _build_content_score_prompt(
            platform=platform,
            title=title,
            text=merged_text + "\n\n=== VIDEO FRAME ANALYSIS ===\n" + visual_block,
            url=source_label,
            metrics={},
            rule=rule,
        )

        ai_text = run_llm(prompt)

        con = sqlite3.connect(DB_PATH)
        cur = con.cursor()
        ensure_content_quality_score_columns(cur)
        cur.execute("""
        CREATE TABLE IF NOT EXISTS content_quality_scores (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            created_at TEXT,
            platform TEXT DEFAULT '',
            external_id TEXT DEFAULT '',
            url TEXT DEFAULT '',
            input_hash TEXT DEFAULT '',
            overall_score REAL DEFAULT 0,
            hook_score REAL DEFAULT 0,
            caption_score REAL DEFAULT 0,
            retention_risk REAL DEFAULT 0,
            engagement_rate_pct REAL DEFAULT 0,
            verdict TEXT DEFAULT '',
            features_json TEXT DEFAULT '',
            analysis TEXT DEFAULT ''
        )
        """)

        cur.execute("""
            INSERT INTO content_quality_scores (
                created_at, platform, external_id, url, input_hash,
                overall_score, hook_score, caption_score, retention_risk,
                engagement_rate_pct, verdict, features_json, analysis
            )
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """, (
            datetime.now().isoformat(timespec="seconds"),
            platform,
            "",
            source_label,
            hashlib.sha256(merged_text.encode("utf-8")).hexdigest(),
            rule["overall_score"],
            rule["hook_score"],
            rule["caption_score"],
            rule["retention_risk"],
            rule["engagement_rate_pct"],
            rule["verdict"],
            json.dumps(rule["features"], ensure_ascii=False),
            ai_text,
        ))

        score_id = cur.lastrowid

        try:
            cur.execute("""
                UPDATE content_quality_scores
                SET transcript=?,
                    frame_analysis_json=?,
                    platform_strategy_json=?,
                    text_only_scores_json=?,
                    visual_scores_json=?
                WHERE id=?
            """, (
                transcript if "transcript" in locals() else "",
                json.dumps(frame_analysis if "frame_analysis" in locals() else {}, ensure_ascii=False),
                json.dumps(rule.get("platform_strategy", {}), ensure_ascii=False),
                json.dumps(rule.get("text_only_scores", {}), ensure_ascii=False),
                json.dumps(rule.get("visual_scores", {}), ensure_ascii=False),
                score_id,
            ))

            actual_metrics = {
                "views": views,
                "likes": likes,
                "comments": comments,
                "saves": saves,
                "shares": shares,
            }

            actual_er = 0
            if views > 0:
                actual_er = round(((likes + comments * 2 + saves * 3 + shares * 3) / views) * 100, 3)

            learning_label = (
                "strong_actual" if actual_er >= 8 or views >= 5000
                else "medium_actual" if actual_er >= 3 or views >= 1000
                else "weak_actual"
            )

            prediction_error = {
                "predicted_overall": rule.get("overall_score"),
                "actual_engagement_rate_pct": actual_er,
                "learning_label": learning_label,
            }

            cur.execute("""
                UPDATE content_quality_scores
                SET actual_metrics_json=?,
                    learning_label=?,
                    prediction_error_json=?
                WHERE id=?
            """, (
                json.dumps(actual_metrics, ensure_ascii=False),
                learning_label,
                json.dumps(prediction_error, ensure_ascii=False),
                score_id,
            ))
        except Exception as _e:
            print("⚠️ content_quality_scores extra update failed:", _e)

        con.commit()
        con.close()

        return {
            "status": "ok",
            "score_id": score_id,
            "source": source_label,
            "transcript": transcript,
            "frame_analysis": frame_analysis,
            "scores": rule,
            "analysis": ai_text,
            "result": ai_text,
        }

    except Exception as e:
        return {
            "status": "error",
            "error": str(e),
            "traceback": traceback.format_exc(),
        }

    finally:
        if tmp_path:
            try:
                os.remove(tmp_path)
            except Exception:
                pass



@app.post("/ai/content-score/attach-actuals")
async def ai_content_score_attach_actuals(request: Request):
    """
    Learning layer:
    після того як платформа дала реальні метрики, прикріплюємо їх до score_id.
    Це не fine-tune LLM. Це калібрує наш scoring algorithm через історію.
    """
    payload = await request.json()
    score_id = int(payload.get("score_id") or 0)
    actual = payload.get("actual_metrics") or {}

    if not score_id:
        return {"status": "error", "error": "score_id required"}

    views = float(actual.get("views") or 0)
    likes = float(actual.get("likes") or 0)
    comments = float(actual.get("comments") or 0)
    saves = float(actual.get("saves") or 0)
    shares = float(actual.get("shares") or 0)

    actual_er = 0
    if views > 0:
        actual_er = round(((likes + comments * 2 + saves * 3 + shares * 3) / views) * 100, 3)

    con = sqlite3.connect(DB_PATH)
    con.row_factory = sqlite3.Row
    cur = con.cursor()
    ensure_content_quality_score_columns(cur)

    row = cur.execute("SELECT * FROM content_quality_scores WHERE id=?", (score_id,)).fetchone()
    if not row:
        con.close()
        return {"status": "error", "error": "score_id not found"}

    predicted = float(row["overall_score"] or 0)

    # простий label для навчання/калібровки
    if actual_er >= 8 or views >= 5000:
        label = "strong_actual"
    elif actual_er >= 3 or views >= 1000:
        label = "medium_actual"
    else:
        label = "weak_actual"

    pred_bucket = "strong_pred" if predicted >= 75 else "medium_pred" if predicted >= 55 else "weak_pred"

    error = {
        "predicted_overall": predicted,
        "actual_engagement_rate_pct": actual_er,
        "prediction_bucket": pred_bucket,
        "actual_label": label,
        "miss": pred_bucket.split("_")[0] != label.split("_")[0],
    }

    cur.execute("""
        UPDATE content_quality_scores
        SET actual_metrics_json=?,
            learning_label=?,
            prediction_error_json=?
        WHERE id=?
    """, (
        json.dumps(actual, ensure_ascii=False),
        label,
        json.dumps(error, ensure_ascii=False),
        score_id,
    ))

    con.commit()
    con.close()

    return {
        "status": "ok",
        "score_id": score_id,
        "learning_label": label,
        "prediction_error": error,
    }


@app.get("/ai/content-score/learning-summary")
def ai_content_score_learning_summary():
    """
    Показує, на чому алгоритм вчиться:
    які score/patterns збігаються або не збігаються з реальними результатами.
    """
    con = sqlite3.connect(DB_PATH)
    con.row_factory = sqlite3.Row
    cur = con.cursor()
    ensure_content_quality_score_columns(cur)

    rows = cur.execute("""
        SELECT
            platform,
            learning_label,
            COUNT(*) AS n,
            ROUND(AVG(overall_score), 2) AS avg_overall,
            ROUND(AVG(hook_score), 2) AS avg_hook,
            ROUND(AVG(caption_score), 2) AS avg_caption,
            ROUND(AVG(retention_risk), 2) AS avg_risk
        FROM content_quality_scores
        WHERE learning_label IS NOT NULL
          AND learning_label != ''
        GROUP BY platform, learning_label
        ORDER BY platform, learning_label
    """).fetchall()

    misses = cur.execute("""
        SELECT id, created_at, platform, overall_score, hook_score, retention_risk,
               learning_label, prediction_error_json
        FROM content_quality_scores
        WHERE prediction_error_json LIKE '%"miss": true%'
        ORDER BY id DESC
        LIMIT 30
    """).fetchall()

    con.close()

    return {
        "status": "ok",
        "summary": [dict(r) for r in rows],
        "recent_misses": [dict(r) for r in misses],
        "how_it_learns": [
            "LLM не fine-tuneиться автоматично.",
            "Ми накопичуємо predicted score + actual metrics.",
            "Потім калібруємо ваги hook/retention/caption/platform для точнішого прогнозу.",
            "Промпт отримує platform-specific правила, а scoring formula отримує platform-specific weights."
        ]
    }


