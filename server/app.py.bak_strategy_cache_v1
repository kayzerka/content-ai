def run_deepseek(prompt: str) -> str:
    if not DEEPSEEK_API_KEY:
        return "DEEPSEEK_ERROR: DEEPSEEK_API_KEY не встановлений у .env"

    url = DEEPSEEK_API_BASE.rstrip("/") + "/chat/completions"

    payload = {
        "model": DEEPSEEK_MODEL,
        "messages": [
            {
                "role": "system",
                "content": (
                    "Ти AI-контент директор для Instagram/Facebook/YouTube "
                    "експерта-регресолога/кармолога. Відповідай українською, "
                    "структуровано, практично, з фокусом на продажі, прогрів, "
                    "бренд і контент-стратегію."
                )
            },
            {"role": "user", "content": prompt}
        ],
        "temperature": 0.75,
        "max_tokens": 1400,
        "stream": False
    }

    try:
        r = requests.post(
            url,
            headers={
                "Authorization": f"Bearer {DEEPSEEK_API_KEY}",
                "Content-Type": "application/json",
            },
            json=payload,
            timeout=90,
        )

        if r.status_code != 200:
            return f"DEEPSEEK_ERROR {r.status_code}:\n{r.text}"

        data = r.json()
        return data["choices"][0]["message"]["content"].strip()

    except Exception as e:
        return f"DEEPSEEK_EXCEPTION: {e}"


def run_local_llm(prompt: str) -> str:
    url = os.getenv("LOCAL_LLM_URL", "http://127.0.0.1:8081/completion")

    payload = {
        "prompt": prompt,
        "n_predict": 700,
        "temperature": 0.7,
        "top_p": 0.9,
        "stream": False
    }

    try:
        r = requests.post(url, json=payload, timeout=600)
        if r.status_code != 200:
            return f"LOCAL_LLM_ERROR {r.status_code}:\n{r.text}"

        data = r.json()
        return data.get("content", "").strip()

    except Exception as e:
        return f"LOCAL_LLM_EXCEPTION: {e}"

def run_llm(prompt: str) -> str:
    cloud = run_deepseek(prompt)

    if not (
        cloud.startswith("DEEPSEEK_ERROR")
        or cloud.startswith("DEEPSEEK_EXCEPTION")
    ):
        return cloud

    local = run_local_llm(prompt)

    return (
        "⚠️ DeepSeek API не спрацював, увімкнувся fallback.\n\n"
        f"{cloud}\n\n"
        "=== LOCAL FALLBACK RESULT ===\n"
        f"{local}"
    )


