        if existing_post:
            cur.execute("""
                UPDATE posts
                SET created_at=?,
                    views=?,
                    likes=?,
                    comments=?,
                    score=?,
                    analysis=CASE
                        WHEN analysis IS NULL OR analysis='' OR analysis LIKE 'Imported from YouTube API%'
                        THEN ?
                        ELSE analysis
                    END
                WHERE id=?
            """, (
                published_at,
                views,
                likes,
                comments,
                calc_score(views, likes, comments, 0, 0),
                "Imported from YouTube API. Updated by safe sync.",
                existing_post["id"],
            ))
            skipped_posts += 1
        else:
            cur.execute("""
                INSERT INTO posts (
                    created_at, platform, url, text,
                    views, likes, comments, saves, shares,
                    analysis, score
                )
