def get_post_metrics(post_id: int):
    """Отримати актуальні метрики поста з БД"""
    con = sqlite3.connect(DB_PATH)
    con.row_factory = sqlite3.Row
    post = con.execute("SELECT * FROM posts WHERE id=?", (post_id,)).fetchone()
    con.close()
    
    if not post:
        return None
    
    views = post["views"] or 0
    likes = post["likes"] or 0
    comments = post["comments"] or 0
    score = post["score"] or 0
    engagement_rate = round(((likes + comments) / views) * 100, 2) if views > 0 else 0
    
    return {
        "views": views,
        "likes": likes,
        "comments": comments,
        "score": score,
        "engagement_rate": engagement_rate
    }


@app.post("/ab_test/create")
def create_ab_test(
    original_content_id: int,
    original_platform_version_id: int,
    changes_made: str = "",
    platform: str = "Instagram"
):
    """Створює A/B тест на основі існуючого контенту"""
    con = sqlite3.connect(DB_PATH)
    con.row_factory = sqlite3.Row
    cur = con.cursor()
    
    # Отримуємо оригінальний контент
    original_content = cur.execute(
        "SELECT * FROM content_items WHERE id=?",
        (original_content_id,)
    ).fetchone()
    
    if not original_content:
        con.close()
        return {"status": "error", "error": "Original content not found"}
    
    # Отримуємо platform_version
    original_pv = cur.execute(
        "SELECT * FROM platform_versions WHERE id=?",
        (original_platform_version_id,)
    ).fetchone()
    
    if not original_pv:
        con.close()
        return {"status": "error", "error": "Platform version not found"}
    
    # Отримуємо пост, пов'язаний з цією версією
    original_post = con.execute(
        "SELECT * FROM posts WHERE url LIKE ? ORDER BY id DESC LIMIT 1",
        (f"%{original_pv['external_url']}%",)
    ).fetchone()
    
    # Отримуємо метрики оригіналу
    original_metrics = get_post_metrics(original_post["id"]) if original_post else {"views": 0, "likes": 0, "comments": 0, "score": 0, "engagement_rate": 0}
    
    # Створюємо новий контент для варіанту B
    cur.execute("""
        INSERT INTO content_items (
            created_at, title, base_caption, video_path, image_path,
            source_platform, source_url, status
        )
        VALUES (?, ?, ?, ?, ?, ?, ?, ?)
    """, (
        datetime.now().isoformat(timespec="seconds"),
        f"[TEST B] {original_content['title']}",
        original_content['base_caption'],
        original_content['video_path'],
        original_content['image_path'],
        original_content['source_platform'],
        original_content['source_url'],
        "draft"
    ))
    test_content_id = cur.lastrowid
    
    # Копіюємо platform_version для варіанту B з позначкою
    cur.execute("""
        INSERT INTO platform_versions (
            created_at, content_id, platform, caption, hashtags,
            location, privacy_status, scheduled_at, publish_status
        )
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
    """, (
        datetime.now().isoformat(timespec="seconds"),
        test_content_id,
        platform,
        f"[TEST B]\nChanges: {changes_made}\n\n{original_pv['caption']}",
        original_pv['hashtags'],
        original_pv['location'],
        original_pv['privacy_status'],
        None,
        "draft"
    ))
    test_pv_id = cur.lastrowid
    
    # Створюємо запис A/B тесту
    cur.execute("""
        INSERT INTO ab_test_pairs (
            created_at, original_content_id, original_platform_version_id,
            original_post_id, test_content_id, test_platform_version_id,
            changes_made, platform,
            original_views, original_likes, original_comments,
            original_score, original_engagement_rate,
            status
        )
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
    """, (
        datetime.now().isoformat(timespec="seconds"),
        original_content_id,
        original_platform_version_id,
        original_post["id"] if original_post else None,
        test_content_id,
        test_pv_id,
        changes_made,
        platform,
        original_metrics["views"],
        original_metrics["likes"],
        original_metrics["comments"],
        original_metrics["score"],
        original_metrics["engagement_rate"],
        "active"
    ))
    
    test_id = cur.lastrowid
    con.commit()
    con.close()
    
    return {
        "status": "ok",
        "test_id": test_id,
        "test_content_id": test_content_id,
        "test_platform_version_id": test_pv_id,
        "message": "A/B test created. Now publish the new version!"
    }


@app.post("/ab_test/complete")
def complete_ab_test(test_id: int, test_post_id: int = None):
    """Завершує A/B тест, порівнює метрики та генерує AI висновок"""
    con = sqlite3.connect(DB_PATH)
    con.row_factory = sqlite3.Row
    cur = con.cursor()
    
    test = cur.execute("SELECT * FROM ab_test_pairs WHERE id=?", (test_id,)).fetchone()
    
    if not test:
        con.close()
        return {"status": "error", "error": "Test not found"}
    
    # Отримуємо метрики тестової версії
    if test_post_id:
        test_metrics = get_post_metrics(test_post_id)
        # Оновлюємо test_post_id в таблиці
        cur.execute("UPDATE ab_test_pairs SET test_post_id=? WHERE id=?", (test_post_id, test_id))
    else:
        test_metrics = {"views": 0, "likes": 0, "comments": 0, "score": 0, "engagement_rate": 0}
    
    # Оновлюємо метрики в таблиці
    cur.execute("""
        UPDATE ab_test_pairs
        SET test_views=?, test_likes=?, test_comments=?,
            test_score=?, test_engagement_rate=?, posted_at=?, status='analyzing'
        WHERE id=?
    """, (
        test_metrics["views"],
        test_metrics["likes"],
        test_metrics["comments"],
        test_metrics["score"],
        test_metrics["engagement_rate"],
        datetime.now().isoformat(timespec="seconds"),
        test_id
    ))
    
    # Розраховуємо покращення
    original_score = test["original_score"] or 1
    test_score = test_metrics["score"] or 0
    improvement = round(((test_score - original_score) / original_score) * 100, 2) if original_score > 0 else 0
    
    winner = "B" if test_score > original_score else "A" if original_score > test_score else "draw"
    
    # Генеруємо AI висновок
    insights_prompt = f"""
Проаналізуй результати A/B тесту для експерта-регресолога.

Оригінальний варіант (A):
- Score: {test["original_score"]}
- Перегляди: {test["original_views"]}
- Лайки: {test["original_likes"]}
- Коментарі: {test["original_comments"]}
- Engagement rate: {test["original_engagement_rate"]}%

Нова версія (B):
- Score: {test_metrics["score"]}
- Перегляди: {test_metrics["views"]}
- Лайки: {test_metrics["likes"]}
- Коментарі: {test_metrics["comments"]}
- Engagement rate: {test_metrics["engagement_rate"]}%

Що було змінено у версії B:
{test["changes_made"]}

Платформа: {test["platform"]}

Дай відповідь українською у форматі JSON:
{{
    "verdict": "A/B/draw",
    "improvement_percent": число,
    "why_it_worked": "пояснення, чому спрацювали/не спрацювали зміни",
    "key_insights": ["інсайт 1", "інсайт 2", "інсайт 3"],
    "recommendations": "що робити далі з цим форматом",
    "next_test_suggestion": "що варто протестувати наступного разу"
}}
"""
    
    insights_result = run_llm(insights_prompt)
    
    # Парсимо JSON з відповіді AI
    import json
    import re
    try:
        json_match = re.search(r'\{.*\}', insights_result, re.DOTALL)
        if json_match:
            insights_data = json.loads(json_match.group())
        else:
            insights_data = {"verdict": winner, "improvement_percent": improvement, "why_it_worked": insights_result[:500]}
    except:
        insights_data = {"verdict": winner, "improvement_percent": improvement, "why_it_worked": insights_result[:500]}
    
    # Фінальне оновлення
    cur.execute("""
        UPDATE ab_test_pairs
        SET winner=?, improvement_percent=?, insights=?, recommendations=?,
            status='completed', analyzed_at=?, updated_at=?
        WHERE id=?
    """, (
        insights_data.get("verdict", winner),
        insights_data.get("improvement_percent", improvement),
        insights_data.get("why_it_worked", ""),
        insights_data.get("recommendations", ""),
        datetime.now().isoformat(timespec="seconds"),
        datetime.now().isoformat(timespec="seconds"),
        test_id
    ))
    
    con.commit()
    con.close()
    
    return {
        "status": "ok",
        "test_id": test_id,
        "winner": insights_data.get("verdict", winner),
        "improvement_percent": insights_data.get("improvement_percent", improvement),
        "insights": insights_data.get("why_it_worked", ""),
        "recommendations": insights_data.get("recommendations", ""),
        "next_suggestion": insights_data.get("next_test_suggestion", "")
    }


