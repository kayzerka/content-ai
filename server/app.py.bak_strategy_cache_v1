# VIDEO FRAME ANALYSIS PATCH V1
# deterministic visual features: frames, brightness, motion, scene-change proxy
# =============================================================================

def extract_video_frames(video_path: str, max_seconds: int = 10, fps: float = 1.0, max_frames: int = 10):
    """
    Extract low-rate frames for visual hook/retention analysis.
    Uses ffmpeg only. No heavy CV deps.
    """
    out_dir = Path(tempfile.mkdtemp(prefix="content_frames_"))
    pattern = str(out_dir / "frame_%03d.jpg")

    cmd = [
        os.getenv("FFMPEG_BIN", "ffmpeg"),
        "-y",
        "-i", video_path,
        "-t", str(max_seconds),
        "-vf", f"fps={fps},scale=360:-1",
        "-q:v", "4",
        pattern,
    ]

    subprocess.run(cmd, check=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)

    frames = sorted(out_dir.glob("frame_*.jpg"))[:max_frames]
    return [str(x) for x in frames], str(out_dir)


def _image_gray_stats(path: str):
    """
    Lightweight image analysis via Pillow if available.
    Returns brightness/contrast and tiny grayscale vector for frame diff.
    """
    try:
        from PIL import Image, ImageStat
    except Exception:
        return {
            "available": False,
            "error": "Pillow not installed. Run: pip install pillow",
            "brightness": 0,
            "contrast": 0,
            "vector": [],
        }

    img = Image.open(path).convert("L").resize((32, 32))
    stat = ImageStat.Stat(img)

    px = list(img.getdata())
    brightness = round(stat.mean[0], 2)
    contrast = round(stat.stddev[0], 2)

    return {
        "available": True,
        "brightness": brightness,
        "contrast": contrast,
        "vector": px,
    }


def analyze_video_frames(video_path: str):
    """
    Gives visual diagnostics without pretending semantic vision:
    - brightness/contrast
    - motion proxy between frames
    - first-frame strength proxy
    - visual retention risk
    """
    frames_dir = ""
    try:
        frames, frames_dir = extract_video_frames(video_path, max_seconds=10, fps=1.0, max_frames=10)

        if not frames:
            return {
                "status": "error",
                "error": "no_frames_extracted",
                "frames": [],
            }

        frame_rows = []
        prev_vec = None
        diffs = []

        for idx, fp in enumerate(frames):
            st = _image_gray_stats(fp)

            diff = 0
            if st.get("available") and prev_vec:
                vec = st.get("vector") or []
                if vec and len(vec) == len(prev_vec):
                    diff = round(sum(abs(a - b) for a, b in zip(vec, prev_vec)) / len(vec), 2)
                    diffs.append(diff)

            if st.get("available"):
                prev_vec = st.get("vector") or prev_vec

            frame_rows.append({
                "sec": idx,
                "file": Path(fp).name,
                "brightness": st.get("brightness", 0),
                "contrast": st.get("contrast", 0),
                "motion_diff_from_prev": diff,
                "analysis_available": bool(st.get("available")),
                "error": st.get("error", ""),
            })

        avg_brightness = round(sum(x["brightness"] for x in frame_rows) / max(1, len(frame_rows)), 2)
        avg_contrast = round(sum(x["contrast"] for x in frame_rows) / max(1, len(frame_rows)), 2)
        avg_motion = round(sum(diffs) / max(1, len(diffs)), 2) if diffs else 0
        max_motion = max(diffs) if diffs else 0

        first = frame_rows[0]
        first_frame_strength = 50
        if first["brightness"] < 35 or first["brightness"] > 230:
            first_frame_strength -= 15
        if first["contrast"] >= 45:
            first_frame_strength += 20
        elif first["contrast"] < 25:
            first_frame_strength -= 10
        if avg_motion >= 18:
            first_frame_strength += 15
        elif avg_motion < 7:
            first_frame_strength -= 10

        visual_retention_risk = 50
        if avg_motion < 7:
            visual_retention_risk += 20
        if avg_contrast < 25:
            visual_retention_risk += 15
        if max_motion < 12:
            visual_retention_risk += 10
        if avg_motion > 22:
            visual_retention_risk -= 10

        first_frame_strength = max(0, min(100, int(first_frame_strength)))
        visual_retention_risk = max(0, min(100, int(visual_retention_risk)))

        verdict = (
            "strong_visual_hook" if first_frame_strength >= 70 and visual_retention_risk <= 45
            else "medium_visual_hook" if first_frame_strength >= 50
            else "weak_visual_hook"
        )

        return {
            "status": "ok",
            "frames_count": len(frame_rows),
            "avg_brightness": avg_brightness,
            "avg_contrast": avg_contrast,
            "avg_motion": avg_motion,
            "max_motion": max_motion,
            "first_frame_strength": first_frame_strength,
            "visual_retention_risk": visual_retention_risk,
            "verdict": verdict,
            "frames": frame_rows,
            "note": "Це deterministic frame analysis: яскравість, контраст, рух/зміна кадру. Це ще не semantic vision/OCR.",
        }

    except Exception as e:
        return {
            "status": "error",
            "error": str(e),
            "traceback": traceback.format_exc(),
        }

    finally:
        if frames_dir:
            try:
                shutil.rmtree(frames_dir)
            except Exception:
                pass


