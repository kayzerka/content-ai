@app.get("/posts/stats")
def posts_stats():
    con = sqlite3.connect(DB_PATH)
    con.row_factory = sqlite3.Row
    cur = con.cursor()

    total_posts = cur.execute("SELECT COUNT(*) AS n FROM posts").fetchone()["n"]
    total_views = cur.execute("SELECT COALESCE(SUM(views),0) AS n FROM posts").fetchone()["n"]
    avg_score = cur.execute("SELECT COALESCE(AVG(score),0) AS n FROM posts").fetchone()["n"]

    top_posts = cur.execute("""
        SELECT id, platform, url, text, views, likes, comments, saves, shares, score
        FROM posts
        ORDER BY score DESC, views DESC
        LIMIT 5
    """).fetchall()

    con.close()

    return {
        "total_posts": total_posts,
        "total_views": total_views,
        "avg_score": round(avg_score, 2),
        "top_posts": [dict(r) for r in top_posts],
    }


