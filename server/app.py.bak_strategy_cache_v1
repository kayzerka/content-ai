def youtube_videos(max_results: int = 10):
    token, err = youtube_get_access_token()
    if err:
        return {"status": "error", "error": err}

    # 1) get uploads playlist
    ch = requests.get(
        "https://www.googleapis.com/youtube/v3/channels",
        headers={"Authorization": f"Bearer {token}"},
        params={
            "part": "contentDetails",
            "mine": "true",
        },
        timeout=30,
    ).json()

    items = ch.get("items", [])
    if not items:
        return {"status": "error", "error": "No channel found", "raw": ch}

    uploads_playlist = items[0]["contentDetails"]["relatedPlaylists"]["uploads"]

    # 2) get videos from uploads playlist
    pl = requests.get(
        "https://www.googleapis.com/youtube/v3/playlistItems",
        headers={"Authorization": f"Bearer {token}"},
        params={
            "part": "snippet,contentDetails",
            "playlistId": uploads_playlist,
            "maxResults": max_results,
        },
        timeout=30,
    ).json()

    video_ids = [
        x["contentDetails"]["videoId"]
        for x in pl.get("items", [])
        if "contentDetails" in x and "videoId" in x["contentDetails"]
    ]

    if not video_ids:
        return {"status": "ok", "videos": []}

    stats = requests.get(
        "https://www.googleapis.com/youtube/v3/videos",
        headers={"Authorization": f"Bearer {token}"},
        params={
            "part": "snippet,statistics",
            "id": ",".join(video_ids),
        },
        timeout=30,
    ).json()

    return {"status": "ok", "videos": stats.get("items", [])}

