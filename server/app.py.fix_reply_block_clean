        s = ig_save_reaction(ev, source="webhook")
        saved.append(s)

        if s.get("reaction_id") and (s.get("inserted") is True):
            try:
                processed.append(ig_process_reaction(int(s["reaction_id"])))
            except Exception as e:
                processed.append({
