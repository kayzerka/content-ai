        }

    if t in ("entertainment", "fun", "розважальний"):
        return {
            "theme": "entertainment",
            "label": "Розважальний контент",
            "primary_goal": "охоплення, реакції, коментарі, репости",
            "score_focus": ["емоція", "темп", "простота", "relatable", "коментарність"],
        }

    return {
