def ai_detect_content_theme(platform: str, text: str) -> dict:
    raw = (text or "").strip()
    if not raw:
        return {"theme": "informational", "confidence": 0, "reason": "empty_text", "cached": False}

    input_hash = hashlib.sha256((platform + "::" + raw[:5000]).encode("utf-8")).hexdigest()

    con = sqlite3.connect(DB_PATH)
    con.row_factory = sqlite3.Row
    cur = con.cursor()
    ensure_content_theme_cache(cur)

    cached = cur.execute("""
        SELECT * FROM content_theme_cache
        WHERE input_hash=?
        LIMIT 1
    """, (input_hash,)).fetchone()

    if cached:
        con.close()
        return {
            "theme": cached["theme"],
            "confidence": cached["confidence"],
            "reason": cached["reason"],
            "cached": True,
            "source": "cache",
        }

    # 2) Local LLM first: cheap/offline classifier
    local = detect_theme_local_llama(platform, raw)
    min_conf = float(os.getenv("LOCAL_THEME_MIN_CONFIDENCE", "0.62"))

    if local and float(local.get("confidence") or 0) >= min_conf:
        cur.execute("""
            INSERT OR REPLACE INTO content_theme_cache (
                created_at, input_hash, platform, theme, confidence, reason
            )
            VALUES (?, ?, ?, ?, ?, ?)
        """, (
            datetime.now().isoformat(timespec="seconds"),
            input_hash,
            platform,
            local["theme"],
            local["confidence"],
            f'{local.get("reason","")} | source=local_llama',
        ))

        con.commit()
        con.close()

        print(f"[THEME] {local['theme']} via local_llama conf={local['confidence']}")
        return {
            "theme": local["theme"],
            "confidence": local["confidence"],
            "reason": local.get("reason", "local_llama"),
            "cached": False,
            "source": "local_llama",
        }

    prompt = f"""
Визнач тип контенту для короткого відео.

Типи:
1. expert — експертний: продає довіру, показує експертність, діагностику, кейс, сеанс, консультацію, результат.
2. informational — інформаційний: пояснює, навчає, дає користь, структуру, причини, кроки.
3. entertainment — розважальний: історія, емоція, relatable, реакція, життєва ситуація, легкість, коментарність.

Визначай по наміру контенту, не по одному слову.

Платформа: {platform}

Текст:
{raw[:5000]}

Відповідай строго JSON:
{{"theme":"expert|informational|entertainment","confidence":0.0,"reason":"коротко чому"}}
"""

    try:
        out = run_llm(prompt)
        m = re.search(r"\{[\s\S]*\}", out or "")
        data = json.loads(m.group(0)) if m else {}

        theme = str(data.get("theme") or "").strip().lower()
        if theme not in ("expert", "informational", "entertainment"):
            raise ValueError("bad_theme")

        confidence = float(data.get("confidence") or 0.7)
        reason = str(data.get("reason") or "ai_classified").strip()

    except Exception as e:
        fb = rule_detect_content_theme(raw)
        theme = fb["theme"]
        confidence = fb["confidence"]
        reason = f"fallback_after_ai_error: {e}"

    cur.execute("""
        INSERT OR REPLACE INTO content_theme_cache (
            created_at, input_hash, platform, theme, confidence, reason
        )
        VALUES (?, ?, ?, ?, ?, ?)
    """, (
        datetime.now().isoformat(timespec="seconds"),
        input_hash,
        platform,
        theme,
        confidence,
        reason,
    ))

    con.commit()
    con.close()

    print(f"[THEME] {theme} via remote_or_fallback conf={confidence}")
    return {"theme": theme, "confidence": confidence, "reason": reason, "cached": False, "source": "remote_or_fallback"}


