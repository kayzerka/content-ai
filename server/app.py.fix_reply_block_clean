def _ig_insights_to_map(raw):
    out = {}
    for item in (raw or {}).get("data", []):
        name = item.get("name")
        values = item.get("values") or []
        val = values[0].get("value") if values and isinstance(values[0], dict) else 0
        try:
            out[name] = int(val or 0)
        except Exception:
            out[name] = val or 0
    return out


@app.get("/api/ig/media")
def api_ig_media(limit: int = 25, enrich: int = 1):
    token, ig_user_id, err = _ig_env()
    if err:
        return err

    r = requests.get(
        f"https://graph.facebook.com/v25.0/{ig_user_id}/media",
        params={
            "fields": "id,caption,media_type,media_product_type,media_url,thumbnail_url,permalink,timestamp,like_count,comments_count",
            "limit": limit,
            "access_token": token,
        },
        timeout=30,
    )

    data = r.json()
    if "error" in data or not enrich:
        return data

    enriched = []
    for item in data.get("data", []):
        media_id = item.get("id")
        insights_raw = {}
        insights = {}

        if media_id:
            # Meta часто міняє назви метрик. Пробуємо набір, якщо частина не підтримується — fallback.
            metric_sets = [
                "views,reach,likes,comments,saved,shares,total_interactions",
                "plays,reach,likes,comments,saved,shares,total_interactions",
                "video_views,reach,likes,comments,saved,shares,total_interactions",
                "reach,likes,comments,saved,shares,total_interactions",
            ]

            for metric in metric_sets:
                rr = requests.get(
                    f"https://graph.facebook.com/v25.0/{media_id}/insights",
                    params={
                        "metric": metric,
                        "access_token": token,
                    },
                    timeout=30,
                )
                insights_raw = rr.json()
                if "error" not in insights_raw:
                    insights = _ig_insights_to_map(insights_raw)
                    break

        views = (
            insights.get("views")
            or insights.get("plays")
            or insights.get("video_views")
            or insights.get("total_views")
            or 0
        )

        item["insights"] = insights
        item["insights_raw"] = insights_raw
        item["views"] = int(views or 0)
        item["reach"] = int(insights.get("reach") or 0)
        item["saves"] = int(insights.get("saved") or insights.get("saves") or 0)
        item["shares"] = int(insights.get("shares") or 0)
        item["total_interactions"] = int(insights.get("total_interactions") or 0)

        enriched.append(item)

    data["data"] = enriched
    data["enriched"] = True
    return data


