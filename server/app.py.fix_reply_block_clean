def ig_extract_events_from_meta_webhook(payload: dict):
    events = []

    for entry in payload.get("entry", []) or []:
        entry_id = str(entry.get("id") or "")

        for change in entry.get("changes", []) or []:
            field = str(change.get("field") or "")
            value = change.get("value") or {}

            raw_hash = hashlib.sha256(ig_json_dumps({"entry": entry, "change": change}).encode("utf-8")).hexdigest()

            events.append({
                "event_type": field or "change",
                "external_event_id": str(
                    value.get("comment_id")
                    or value.get("id")
                    or value.get("mid")
                    or raw_hash
                ),
                "external_user_id": str(
                    (value.get("from") or {}).get("id")
                    or value.get("sender_id")
                    or value.get("user_id")
                    or ""
                ),
                "username": str(
                    (value.get("from") or {}).get("username")
                    or (value.get("from") or {}).get("name")
                    or value.get("username")
                    or ""
                ),
                "media_id": str((value.get("media") or {}).get("id") or value.get("media_id") or entry_id),
                "media_url": str((value.get("media") or {}).get("permalink") or value.get("permalink") or ""),
                "reaction_text": str(
                    value.get("text")
                    or value.get("message")
                    or value.get("comment")
                    or value.get("caption")
                    or ""
                ),
                "raw": {"entry": entry, "change": change},
            })

        for msg_event in entry.get("messaging", []) or []:
            sender = msg_event.get("sender") or {}
            message = msg_event.get("message") or {}
            postback = msg_event.get("postback") or {}
            text = str(message.get("text") or postback.get("title") or postback.get("payload") or "")
            mid = str(message.get("mid") or "")

            events.append({
                "event_type": "message",
                "external_event_id": mid or hashlib.sha256(ig_json_dumps(msg_event).encode("utf-8")).hexdigest(),
                "external_user_id": str(sender.get("id") or ""),
                "username": "",
                "media_id": "",
                "media_url": "",
                "reaction_text": text,
                "raw": {"entry": entry, "messaging": msg_event},
            })

    return [e for e in events if e.get("external_event_id")]


