def ig_trim_text(text: str, min_len: int, max_len: int):
    if not text:
        return ""
    text = text.strip()

    if len(text) <= max_len:
        return text

    # обрізаємо по останній крапці/комі/пробілу
    cut = text[:max_len]
    m = re.search(r"(.+[\.\!\?\n])", cut)
    if m:
        return m.group(1).strip()

    # fallback — по пробілу
    cut = cut.rsplit(" ", 1)[0]
    return cut.strip() + "…"


