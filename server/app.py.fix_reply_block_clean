def rule_detect_content_theme(text: str) -> dict:
    txt = (text or "").lower()

    expert = sum(2 for k in ["сеанс", "регрес", "клієнт", "зціл", "травма", "карм", "я вирішу", "практик", "спеціаліст"] if k in txt)
    informational = sum(2 for k in ["як", "чому", "що робити", "причини", "ознаки", "пояснюю", "крок", "спосіб"] if k in txt)
    entertainment = sum(2 for k in ["уявляєш", "уявляєте", "думки в голос", "чоловік", "історія", "вау", "реально", "жиза"] if k in txt)

    scores = {"expert": expert, "informational": informational, "entertainment": entertainment}
    theme = max(scores, key=scores.get)
    if scores[theme] <= 0:
        theme = "informational"

    return {"theme": theme, "confidence": 0.45, "reason": "rule_fallback", "scores": scores}




