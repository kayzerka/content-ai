def ig_save_reaction(event: dict, source: str = "webhook"):
    con = sqlite3.connect(DB_PATH)
    cur = con.cursor()

    now = datetime.now().isoformat(timespec="seconds")

    try:
        cur.execute("""
            INSERT INTO ig_reactions (
                created_at, source, platform, event_type,
                external_event_id, external_user_id, username,
                media_id, media_url, reaction_text, raw_json, status
            )
            VALUES (?, ?, 'instagram', ?, ?, ?, ?, ?, ?, ?, ?, 'new')
        """, (
            now,
            source,
            event.get("event_type") or "",
            event.get("external_event_id") or "",
            event.get("external_user_id") or "",
            event.get("username") or "",
            event.get("media_id") or "",
            event.get("media_url") or "",
            event.get("reaction_text") or "",
            ig_json_dumps(event.get("raw") or event),
        ))
        reaction_id = cur.lastrowid
        inserted = True
    except sqlite3.IntegrityError:
        row = cur.execute("""
            SELECT id FROM ig_reactions
            WHERE external_event_id=?
            LIMIT 1
        """, (event.get("external_event_id") or "",)).fetchone()
        reaction_id = row[0] if row else 0
        inserted = False

    con.commit()
    con.close()

    return {"reaction_id": reaction_id, "inserted": inserted}


