@app.post("/ai/cache/clear")
def ai_cache_clear():
    import sqlite3
    from pathlib import Path

    candidates = [
        Path("db.sqlite"),
        Path("content_ai.sqlite"),
        Path("data.sqlite"),
        Path("server.sqlite"),
        Path("app.sqlite"),
    ]

    cleared = []

    for db_path in candidates:
        if not db_path.exists():
            continue

        try:
            conn = sqlite3.connect(str(db_path))
            cur = conn.cursor()

            cur.execute("SELECT name FROM sqlite_master WHERE type='table'")
            tables = [r[0] for r in cur.fetchall()]

            for t in tables:
                if any(x in t.lower() for x in ["cache", "analysis", "ai"]):
                    try:
                        cur.execute(f'DELETE FROM "{t}"')
                        cleared.append(f"{db_path}:{t}")
                    except Exception:
                        pass

            conn.commit()
            conn.close()
        except Exception:
            pass

    return {
        "status": "ok",
        "cleared": cleared,
    }
