def detect_theme_local_llama(platform: str, text: str) -> dict | None:
    cli = os.getenv("LOCAL_LLM_CLI", "").strip()
    model = os.getenv("LOCAL_LLM_MODEL", "").strip()

    if not cli or not model:
        return None

    if not Path(cli).exists() or not Path(model).exists():
        print(f"[THEME][LOCAL] missing cli/model cli={cli} model={model}")
        return None

    raw = (text or "").strip()
    if not raw:
        return None

    prompt = f"""
You classify short-form social media content.

Return ONLY valid JSON:
{{"theme":"expert|informational|entertainment","confidence":0.0,"reason":"short reason"}}

Definitions:
- expert: builds authority/trust, sells expertise, session, consultation, client case, diagnosis, result.
- informational: teaches, explains, gives steps, reasons, signs, practical value.
- entertainment: story, emotion, relatable situation, reaction, light viral context.

Classify by intent, not by one keyword.

Platform: {platform}

Text:
{raw[:1800]}
"""

    try:
        cmd = [
            cli,
            "-m", model,
            "-p", prompt,
            "-n", os.getenv("LOCAL_THEME_MAX_TOKENS", "160"),
            "--temp", os.getenv("LOCAL_THEME_TEMP", "0.1"),
        ]

        r = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            timeout=int(os.getenv("LOCAL_THEME_TIMEOUT", "35")),
        )

        out = (r.stdout or "").strip()
        start = out.find("{")
        end = out.rfind("}") + 1

        if start < 0 or end <= start:
            print("[THEME][LOCAL] no json output:", out[:300])
            return None

        data = json.loads(out[start:end])
        theme = str(data.get("theme") or "").strip().lower()

        if theme not in ("expert", "informational", "entertainment"):
            print("[THEME][LOCAL] bad theme:", theme)
            return None

        confidence = float(data.get("confidence") or 0.6)
        reason = str(data.get("reason") or "local_llama").strip()

        return {
            "theme": theme,
            "confidence": confidence,
            "reason": reason,
            "source": "local_llama",
        }

    except Exception as e:
        print("[THEME][LOCAL] error:", e)
        return None

