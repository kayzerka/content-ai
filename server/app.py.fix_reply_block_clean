            ))

            actual_metrics = {
                "views": views,
                "likes": likes,
                "comments": comments,
                "saves": saves,
                "shares": shares,
            }

            actual_er = 0
            if views > 0:
                actual_er = round(((likes + comments * 2 + saves * 3 + shares * 3) / views) * 100, 3)

            learning_label = (
                "strong_actual" if actual_er >= 8 or views >= 5000
                else "medium_actual" if actual_er >= 3 or views >= 1000
                else "weak_actual"
            )

            prediction_error = {
                "predicted_overall": rule.get("overall_score"),
                "actual_engagement_rate_pct": actual_er,
                "learning_label": learning_label,
            }

            cur.execute("""
                UPDATE content_quality_scores
                SET actual_metrics_json=?,
                    learning_label=?,
                    prediction_error_json=?
                WHERE id=?
            """, (
                json.dumps(actual_metrics, ensure_ascii=False),
                learning_label,
                json.dumps(prediction_error, ensure_ascii=False),
                score_id,
            ))
        except Exception as _e:
            print("⚠️ content_quality_scores extra update failed:", _e)

        con.commit()
        con.close()

        return {
            "status": "ok",
            "score_id": score_id,
            "source": source_label,
            "transcript": transcript,
            "frame_analysis": frame_analysis,
            "scores": rule,
            "analysis": ai_text,
            "result": ai_text,
        }

    except Exception as e:
        return {
            "status": "error",
            "error": str(e),
            "traceback": traceback.format_exc(),
        }

    finally:
        if tmp_path:
            try:
                os.remove(tmp_path)
            except Exception:
                pass



@app.post("/ai/content-score/attach-actuals")
async def ai_content_score_attach_actuals(request: Request):
    """
    Learning layer:
    після того як платформа дала реальні метрики, прикріплюємо їх до score_id.
    Це не fine-tune LLM. Це калібрує наш scoring algorithm через історію.
    """
    payload = await request.json()
    score_id = int(payload.get("score_id") or 0)
    actual = payload.get("actual_metrics") or {}

    if not score_id:
        return {"status": "error", "error": "score_id required"}

    views = float(actual.get("views") or 0)
    likes = float(actual.get("likes") or 0)
    comments = float(actual.get("comments") or 0)
    saves = float(actual.get("saves") or 0)
    shares = float(actual.get("shares") or 0)

    actual_er = 0
    if views > 0:
        actual_er = round(((likes + comments * 2 + saves * 3 + shares * 3) / views) * 100, 3)

    con = sqlite3.connect(DB_PATH)
    con.row_factory = sqlite3.Row
    cur = con.cursor()
    ensure_content_quality_score_columns(cur)

    row = cur.execute("SELECT * FROM content_quality_scores WHERE id=?", (score_id,)).fetchone()
    if not row:
        con.close()
        return {"status": "error", "error": "score_id not found"}

    predicted = float(row["overall_score"] or 0)

    # простий label для навчання/калібровки
    if actual_er >= 8 or views >= 5000:
        label = "strong_actual"
    elif actual_er >= 3 or views >= 1000:
        label = "medium_actual"
    else:
        label = "weak_actual"

    pred_bucket = "strong_pred" if predicted >= 75 else "medium_pred" if predicted >= 55 else "weak_pred"

    error = {
        "predicted_overall": predicted,
        "actual_engagement_rate_pct": actual_er,
        "prediction_bucket": pred_bucket,
        "actual_label": label,
        "miss": pred_bucket.split("_")[0] != label.split("_")[0],
    }

    cur.execute("""
        UPDATE content_quality_scores
        SET actual_metrics_json=?,
            learning_label=?,
            prediction_error_json=?
        WHERE id=?
    """, (
        json.dumps(actual, ensure_ascii=False),
        label,
        json.dumps(error, ensure_ascii=False),
        score_id,
    ))

    con.commit()
    con.close()

    return {
        "status": "ok",
        "score_id": score_id,
        "learning_label": label,
        "prediction_error": error,
    }


