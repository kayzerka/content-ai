@app.post("/youtube/upload_platform_version")
def youtube_upload_platform_version(platform_version_id: int):
    con = sqlite3.connect(DB_PATH)
    con.row_factory = sqlite3.Row
    cur = con.cursor()

    pv = cur.execute("""
        SELECT *
        FROM platform_versions
        WHERE id=?
    """, (platform_version_id,)).fetchone()

    if not pv:
        con.close()
        return {"status": "error", "error": "platform_version_id not found"}

    if str(pv["platform"]).lower() != "youtube":
        con.close()
        return {
            "status": "error",
            "error": f"platform_version_id={platform_version_id} is platform={pv['platform']}, not YouTube",
        }

    item = cur.execute("""
        SELECT *
        FROM content_items
        WHERE id=?
    """, (pv["content_id"],)).fetchone()

    if not item:
        con.close()
        return {"status": "error", "error": "content item not found"}

    video_path = (item["video_path"] or "").strip()

    if not video_path:
        con.close()
        return {
            "status": "error",
            "error": "content_items.video_path is empty",
        }

    if not Path(video_path).exists():
        con.close()
        return {
            "status": "error",
            "error": f"video file not found: {video_path}",
        }

    title = (item["title"] or "").strip() or "Uploaded video"
    description = (pv["caption"] or "").strip()

    hashtags = (pv["hashtags"] or "").strip()
    if hashtags and hashtags not in description:
        description = (description + "\n\n" + hashtags).strip()

    privacy_status = (pv["privacy_status"] or "private").strip().lower()
    if privacy_status not in ("private", "unlisted", "public"):
        privacy_status = "private"

    body = {
        "snippet": {
            "title": title[:100],
            "description": description,
            "tags": [x.strip().lstrip("#") for x in hashtags.split() if x.strip()],
            "categoryId": _guess_youtube_category_id(pv),
        },
        "status": {
            "privacyStatus": privacy_status,
            "selfDeclaredMadeForKids": False,
        },
    }

    try:
        youtube = get_youtube_oauth_client()

        media = MediaFileUpload(
            video_path,
            chunksize=-1,
            resumable=True,
        )

        request = youtube.videos().insert(
            part="snippet,status",
            body=body,
            media_body=media,
        )

