def blend_text_visual_scores(rule: dict, frame_analysis: dict, platform: str = "") -> dict:
    """
    Final score = text/transcript score + visual frame score.
    This is deterministic calibration layer before LLM explanation.
    """
    rule = dict(rule or {})
    frame_analysis = frame_analysis or {}
    strategy = build_platform_strategy(platform)
    w = strategy.get("score_weights") or {}

    text_hook = float(rule.get("hook_score") or 0)
    text_risk = float(rule.get("retention_risk") or 0)
    caption = float(rule.get("caption_score") or 0)
    er = float(rule.get("engagement_rate_pct") or 0)

    visual_hook = float(frame_analysis.get("first_frame_strength") or text_hook)
    visual_risk = float(frame_analysis.get("visual_retention_risk") or text_risk)

    final_hook = round(text_hook * 0.70 + visual_hook * 0.30, 2)
    final_risk = round(text_risk * 0.65 + visual_risk * 0.35, 2)

    engagement_component = min(100, er * 8)

    hook_w = float(w.get("hook", 0.34))
    retention_w = float(w.get("retention", 0.30))
    caption_w = float(w.get("caption", 0.18))
    engagement_w = float(w.get("engagement", 0.18))

    final_overall = round(
        final_hook * hook_w +
        (100 - final_risk) * retention_w +
        caption * caption_w +
        engagement_component * engagement_w,
        2
    )

    verdict = "strong" if final_overall >= 75 else "medium" if final_overall >= 50 else "weak"

    rule["text_only_scores"] = {
        "overall_score": rule.get("overall_score"),
        "hook_score": rule.get("hook_score"),
        "retention_risk": rule.get("retention_risk"),
        "caption_score": rule.get("caption_score"),
    }
    rule["visual_scores"] = {
        "first_frame_strength": frame_analysis.get("first_frame_strength"),
        "visual_retention_risk": frame_analysis.get("visual_retention_risk"),
        "avg_motion": frame_analysis.get("avg_motion"),
        "avg_contrast": frame_analysis.get("avg_contrast"),
        "visual_verdict": frame_analysis.get("verdict"),
    }
    rule["platform_strategy"] = strategy

    rule["overall_score"] = _norm_pct(final_overall)
    rule["hook_score"] = _norm_pct(final_hook)
    rule["retention_risk"] = _norm_pct(final_risk)
    rule["verdict"] = verdict

    return rule




