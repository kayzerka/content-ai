        return str(obj)


def ig_extract_json_object(text: str):
    text = (text or "").strip()
    if not text:
        return None
    try:
        return _json.loads(text)
    except Exception:
        pass

    import re
    m = re.search(r"\{.*\}", text, flags=re.DOTALL)
