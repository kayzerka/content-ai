def _norm_pct(x):
    try:
        return max(0, min(100, int(round(float(x)))))
    except Exception:
        return 0


def _content_quality_rule_score(text: str, platform: str = "", metrics: dict | None = None):
    metrics = metrics or {}
    raw = (text or "").strip()
    low = raw.lower()
    words = [w for w in re.split(r"\s+", raw) if w.strip()]
    first_12 = " ".join(words[:12]).lower()

    pain_markers = [
        "бол", "страх", "проблем", "чому", "не мож", "важко", "втом", "застряг",
        "схуд", "результат", "криза", "тривог", "гроші", "стосунк", "дитин",
        "безплід", "винош", "здоров", "карм", "регрес"
    ]
    curiosity_markers = [
        "уяви", "секрет", "поки", "ніколи", "правда", "ось", "це", "тому",
        "помилка", "причина", "знак", "неочевид", "після цього"
    ]
    cta_markers = [
        "напиши", "коментар", "збереж", "підпиш", "direct", "дірект",
        "запис", "консультац", "поділись"
    ]

    has_question = "?" in raw or first_12.startswith(("чому", "як", "що", "коли"))
    has_number = bool(re.search(r"\d", raw))
    has_pain = any(x in low for x in pain_markers)
    has_curiosity = any(x in low for x in curiosity_markers)
    has_cta = any(x in low for x in cta_markers)

    first_sentence = re.split(r"[.!?\n]", raw)[0].strip()
    first_len = len(first_sentence.split())

    hook_score = 35
    if first_len and first_len <= 10:
        hook_score += 18
    elif first_len <= 16:
        hook_score += 10
    else:
        hook_score -= 8
    if has_question: hook_score += 12
    if has_number: hook_score += 8
    if has_pain: hook_score += 15
    if has_curiosity: hook_score += 12

    caption_score = 35
    if 40 <= len(words) <= 180: caption_score += 15
    if has_cta: caption_score += 18
    if has_pain: caption_score += 12
    if has_curiosity: caption_score += 10
    if has_number: caption_score += 8

    retention_risk = 65
    if first_len > 16: retention_risk += 15
    if not has_pain: retention_risk += 10
    if not has_curiosity: retention_risk += 8
    if has_question or has_number: retention_risk -= 10
    if has_cta: retention_risk -= 5

    views = int(metrics.get("views") or 0)
    likes = int(metrics.get("likes") or 0)
    comments = int(metrics.get("comments") or 0)
    saves = int(metrics.get("saves") or 0)
    shares = int(metrics.get("shares") or 0)

    er = 0.0
    if views > 0:
        er = round(((likes + comments * 2 + saves * 3 + shares * 3) / views) * 100, 3)

    overall = (
        _norm_pct(hook_score) * 0.38 +
        (100 - _norm_pct(retention_risk)) * 0.22 +
        _norm_pct(caption_score) * 0.25 +
        min(100, er * 8) * 0.15
    )

    verdict = "strong" if overall >= 75 else "medium" if overall >= 55 else "weak"

    return {
        "overall_score": _norm_pct(overall),
        "hook_score": _norm_pct(hook_score),
        "caption_score": _norm_pct(caption_score),
        "retention_risk": _norm_pct(retention_risk),
        "engagement_rate_pct": er,
        "verdict": verdict,
        "features": {
            "words": len(words),
            "first_sentence_words": first_len,
            "has_question": has_question,
            "has_number": has_number,
            "has_pain_trigger": has_pain,
            "has_curiosity_gap": has_curiosity,
            "has_cta": has_cta,
            "first_12_words": first_12,
        }
    }


