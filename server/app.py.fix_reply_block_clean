                engagement_rate_pct, verdict, features_json, analysis
            )
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """, (
            datetime.now().isoformat(timespec="seconds"),
            platform,
            "",
            source_label,
            hashlib.sha256(merged_text.encode("utf-8")).hexdigest(),
            rule["overall_score"],
            rule["hook_score"],
            rule["caption_score"],
            rule["retention_risk"],
            rule["engagement_rate_pct"],
            rule["verdict"],
            json.dumps(rule["features"], ensure_ascii=False),
            ai_text,
        ))

        score_id = cur.lastrowid

        try:
            cur.execute("""
                UPDATE content_quality_scores
                SET transcript=?,
                    frame_analysis_json=?,
                    platform_strategy_json=?,
                    text_only_scores_json=?,
                    visual_scores_json=?
                WHERE id=?
            """, (
                transcript if "transcript" in locals() else "",
                json.dumps(frame_analysis if "frame_analysis" in locals() else {}, ensure_ascii=False),
                json.dumps(rule.get("platform_strategy", {}), ensure_ascii=False),
                json.dumps(rule.get("text_only_scores", {}), ensure_ascii=False),
                json.dumps(rule.get("visual_scores", {}), ensure_ascii=False),
