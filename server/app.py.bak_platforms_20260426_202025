@app.get("/youtube/videos")
def youtube_videos(max_results: int = 10):
    token, err = youtube_get_access_token()
    if err:
        return {"status": "error", "error": err}

    # 1) get uploads playlist
    ch = requests.get(
        "https://www.googleapis.com/youtube/v3/channels",
        headers={"Authorization": f"Bearer {token}"},
        params={
            "part": "contentDetails",
            "mine": "true",
        },
        timeout=30,
    ).json()

    items = ch.get("items", [])
    if not items:
        return {"status": "error", "error": "No channel found", "raw": ch}

    uploads_playlist = items[0]["contentDetails"]["relatedPlaylists"]["uploads"]

    # 2) get videos from uploads playlist
    pl = requests.get(
        "https://www.googleapis.com/youtube/v3/playlistItems",
        headers={"Authorization": f"Bearer {token}"},
        params={
            "part": "snippet,contentDetails",
            "playlistId": uploads_playlist,
            "maxResults": max_results,
        },
        timeout=30,
    ).json()

    video_ids = [
        x["contentDetails"]["videoId"]
        for x in pl.get("items", [])
        if "contentDetails" in x and "videoId" in x["contentDetails"]
    ]

    if not video_ids:
        return {"status": "ok", "videos": []}

    stats = requests.get(
        "https://www.googleapis.com/youtube/v3/videos",
        headers={"Authorization": f"Bearer {token}"},
        params={
            "part": "snippet,statistics",
            "id": ",".join(video_ids),
        },
        timeout=30,
    ).json()

    return {"status": "ok", "videos": stats.get("items", [])}

@app.get("/youtube/public/videos")
def youtube_public_videos(max_results: int = 10):
    api_key = os.getenv("YOUTUBE_API_KEY", "").strip()
    channel_id = os.getenv("YOUTUBE_CHANNEL_ID", "").strip()

    if not api_key or not channel_id:
        return {"status": "error", "error": "YOUTUBE_API_KEY або YOUTUBE_CHANNEL_ID не встановлені у .env"}

    search = requests.get(
        "https://www.googleapis.com/youtube/v3/search",
        params={
            "key": api_key,
            "channelId": channel_id,
            "part": "snippet,id",
            "order": "date",
            "maxResults": max_results,
            "type": "video",
        },
        timeout=30,
    ).json()

    video_ids = [
        item["id"]["videoId"]
        for item in search.get("items", [])
        if item.get("id", {}).get("videoId")
    ]

    if not video_ids:
        return {"status": "ok", "videos": []}

    stats = requests.get(
        "https://www.googleapis.com/youtube/v3/videos",
        params={
            "key": api_key,
            "id": ",".join(video_ids),
            "part": "snippet,statistics",
        },
        timeout=30,
    ).json()

    return {"status": "ok", "videos": stats.get("items", [])}


@app.post("/youtube/public/sync")
def youtube_public_sync(max_results: int = 10):
    data = youtube_public_videos(max_results=max_results)

    if data.get("status") != "ok":
        return data

    videos = data.get("videos", [])
    saved = 0

    con = sqlite3.connect(DB_PATH)
    cur = con.cursor()

    for v in videos:
        video_id = v["id"]
        snippet = v.get("snippet", {})
        statistics = v.get("statistics", {})

        title = snippet.get("title", "")
        description = snippet.get("description", "")
        url = f"https://www.youtube.com/watch?v={video_id}"

        views = int(statistics.get("viewCount", 0))
        likes = int(statistics.get("likeCount", 0)) if "likeCount" in statistics else 0
        comments = int(statistics.get("commentCount", 0)) if "commentCount" in statistics else 0

        text = f"{title}\n\n{description}".strip()
        score = calc_score(views, likes, comments, 0, 0)

        analysis = run_llm(f"""
Проаналізуй YouTube відео для експерта-регресолога/кармолога.

Назва:
{title}

Опис:
{description}

Метрики:
views={views}
likes={likes}
comments={comments}
score={score}

Дай:
1. Тема
2. Біль аудиторії
3. Сила заголовка
4. Що покращити
5. 3 ідеї наступних Shorts/Reels
""")

        cur.execute("""
            INSERT INTO posts (
                created_at, platform, url, text,
                views, likes, comments, saves, shares,
                analysis, score
            )
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """, (
            datetime.now().isoformat(timespec="seconds"),
            "YouTube",
            url,
            text,
            views,
            likes,
            comments,
            0,
            0,
            analysis,
            score,
        ))

        saved += 1

    con.commit()
    con.close()

    return {"status": "ok", "saved": saved}
