@app.get("/callback/instagram")
def callback_instagram(code: str = "", error: str = "", error_description: str = ""):
    if error:
        return {
            "status": "error",
            "error": error,
            "error_description": error_description,
        }

    app_id = os.getenv("META_APP_ID", "").strip()
    app_secret = os.getenv("META_APP_SECRET", "").strip()
    redirect_uri = os.getenv("META_REDIRECT_URI", "http://127.0.0.1:8000/callback/instagram").strip()

    if not app_id or not app_secret:
        return {"status": "error", "message": "META_APP_ID або META_APP_SECRET не встановлені у .env"}

    token_url = "https://graph.facebook.com/v19.0/oauth/access_token"

    r = requests.get(token_url, params={
        "client_id": app_id,
        "client_secret": app_secret,
        "redirect_uri": redirect_uri,
        "code": code,
    }, timeout=30)

    data = r.json()

    if "access_token" not in data:
        return {
            "status": "error",
            "step": "exchange_code_for_token",
            "response": data,
        }

    access_token = data["access_token"]

    # save token locally
    con = sqlite3.connect(DB_PATH)
    cur = con.cursor()
    cur.execute("""
    CREATE TABLE IF NOT EXISTS integrations (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        platform TEXT,
        access_token TEXT,
        raw_json TEXT,
        created_at TEXT
    )
    """)
    cur.execute(
        "INSERT INTO integrations (platform, access_token, raw_json, created_at) VALUES (?, ?, ?, ?)",
        ("instagram", access_token, str(data), datetime.now().isoformat(timespec="seconds"))
    )
    con.commit()
    con.close()

    return {
        "status": "connected",
        "platform": "instagram",
        "message": "Instagram/Facebook токен отримано і збережено локально.",
        "next": "Відкрий /instagram/status для перевірки.",
    }


