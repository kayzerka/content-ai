def calc_score(views, likes, comments, saves, shares):
    if views <= 0:
        return 0
    return round(((likes + comments * 3 + saves * 4 + shares * 5) / views) * 1000, 2)


def find_llama_cli():
    candidates = [
        shutil.which("llama-cli"),
        shutil.which("main"),
        "/Volumes/B/Regresolog/content_ai/llama.cpp/build/bin/llama-cli",
        "/Volumes/B/Regresolog/llama.cpp/build/bin/llama-cli",
