def init_db():
    os.makedirs(os.path.dirname(DB_PATH), exist_ok=True)

    con = sqlite3.connect(DB_PATH)
    cur = con.cursor()

    cur.execute("""
    CREATE TABLE IF NOT EXISTS posts (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        created_at TEXT,
        platform TEXT,
        url TEXT DEFAULT '',
        text TEXT,
        views INTEGER DEFAULT 0,
        likes INTEGER DEFAULT 0,
        comments INTEGER DEFAULT 0,
        saves INTEGER DEFAULT 0,
        shares INTEGER DEFAULT 0,
        analysis TEXT DEFAULT '',
        score REAL DEFAULT 0
    )
    """)

    # safe migrations
    cols = [r[1] for r in cur.execute("PRAGMA table_info(posts)").fetchall()]
    if "url" not in cols:
        cur.execute("ALTER TABLE posts ADD COLUMN url TEXT DEFAULT ''")
    if "analysis" not in cols:
        cur.execute("ALTER TABLE posts ADD COLUMN analysis TEXT DEFAULT ''")

    con.commit()
    con.close()


