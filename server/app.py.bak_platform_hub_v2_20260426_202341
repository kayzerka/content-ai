@app.post("/youtube/sync_public")
def youtube_sync_public(channel_id: str, max_results: int = 10):
    data = get_youtube_public_videos(channel_id, max_results)

    if data.get("status") != "ok":
        return data

    con = sqlite3.connect(DB_PATH)
    cur = con.cursor()

    saved = 0

    for v in data.get("videos", []):
        video_id = v.get("id", "")
        snippet = v.get("snippet", {})
        statistics = v.get("statistics", {})

        title = snippet.get("title", "")
        description = snippet.get("description", "")
        url = f"https://www.youtube.com/watch?v={video_id}"

        views = int(statistics.get("viewCount", 0) or 0)
        likes = int(statistics.get("likeCount", 0) or 0)
        comments = int(statistics.get("commentCount", 0) or 0)

        cur.execute("""
            INSERT INTO post_metrics (
                collected_at, platform, external_post_id, external_url,
                title, views, likes, comments, raw_json
            )
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
        """, (
            datetime.now().isoformat(timespec="seconds"),
            "youtube",
            video_id,
            url,
            title,
            views,
            likes,
            comments,
            str(v),
        ))

        cur.execute("""
            INSERT INTO posts (
                created_at, platform, url, text,
                views, likes, comments, saves, shares,
                analysis, score
            )
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """, (
            datetime.now().isoformat(timespec="seconds"),
            "YouTube",
            url,
            f"{title}\n\n{description}".strip(),
            views,
            likes,
            comments,
            0,
            0,
            "Imported from YouTube API. AI analysis not generated yet.",
            calc_score(views, likes, comments, 0, 0),
        ))

        saved += 1

    con.commit()
    con.close()

    return {
        "status": "ok",
        "saved": saved,
        "message": "YouTube відео + метрики збережено в posts і post_metrics.",
    }


