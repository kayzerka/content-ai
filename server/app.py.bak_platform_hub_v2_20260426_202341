    con.row_factory = sqlite3.Row
    cur = con.cursor()

    item = cur.execute("""
        SELECT *
        FROM content_items
        WHERE id=?
    """, (content_id,)).fetchone()

    if not item:
        con.close()
        return {"status": "error", "error": "content_id not found"}

    prompt = f"""
Ти AI-контент директор.

Є один базовий контент:

Назва:
{item["title"]}

Базовий caption:
{item["base_caption"]}

Платформи:
{platforms}

Зроби адаптацію окремо під кожну платформу:
- Instagram Reels
- TikTok
- YouTube Shorts
- Facebook Reels

Для кожної платформи дай:
1. caption
2. хук першого рядка
3. hashtags
4. CTA
5. місцеположення/гео, якщо доречно
6. privacy/status рекомендацію
7. що НЕ писати на цій платформі

Відповідь зроби структуровано українською.
"""

    ai_result = run_llm(prompt)

    for platform in [p.strip() for p in platforms.split(",") if p.strip()]:
        cur.execute("""
            INSERT INTO platform_versions (
                created_at, content_id, platform, caption,
                hashtags, location, privacy_status, publish_status
            )
            VALUES (?, ?, ?, ?, ?, ?, ?, ?)
        """, (
            datetime.now().isoformat(timespec="seconds"),
            content_id,
            platform,
            ai_result,
            "",
            "",
            "private" if platform.lower() in ("youtube", "facebook") else "",
            "draft",
        ))

    con.commit()
    con.close()

    return {
        "status": "ok",
        "content_id": content_id,
        "platforms": platforms,
        "ai_adaptation": ai_result,
    }


