@app.post("/schedule/add")
def schedule_add(
    platform_version_id: int,
    scheduled_at: str,
):
    con = sqlite3.connect(DB_PATH)
    con.row_factory = sqlite3.Row
    cur = con.cursor()

    pv = cur.execute("""
        SELECT *
        FROM platform_versions
        WHERE id=?
    """, (platform_version_id,)).fetchone()

    if not pv:
        con.close()
        return {"status": "error", "error": "platform_version_id not found"}

    cur.execute("""
        INSERT INTO scheduled_posts (
            created_at, content_id, platform_version_id,
            platform, scheduled_at, status
        )
        VALUES (?, ?, ?, ?, ?, ?)
    """, (
        datetime.now().isoformat(timespec="seconds"),
        pv["content_id"],
        platform_version_id,
        pv["platform"],
        scheduled_at,
        "scheduled",
    ))

    cur.execute("""
        UPDATE platform_versions
        SET scheduled_at=?, publish_status='scheduled'
        WHERE id=?
    """, (scheduled_at, platform_version_id))

    schedule_id = cur.lastrowid
    con.commit()
    con.close()

    return {"status": "ok", "schedule_id": schedule_id}


@app.get("/calendar/events")
def calendar_events():
    con = sqlite3.connect(DB_PATH)
    con.row_factory = sqlite3.Row

    rows = con.execute("""
        SELECT
            s.id,
            s.platform,
            s.scheduled_at,
            s.status,
            c.title,
            pv.caption
        FROM scheduled_posts s
        LEFT JOIN content_items c ON c.id = s.content_id
        LEFT JOIN platform_versions pv ON pv.id = s.platform_version_id
        ORDER BY s.scheduled_at ASC
        LIMIT 500
    """).fetchall()

    con.close()

    events = []
    for r in rows:
        events.append({
            "id": r["id"],
            "title": f'{r["platform"]}: {r["title"] or "content"}',
            "start": r["scheduled_at"],
            "status": r["status"],
            "platform": r["platform"],
            "caption": r["caption"],
        })

    return {"events": events}


@app.post("/scheduler/run_once")
def scheduler_run_once():
    """
    Поки що це безпечний dry-run.
    Він знаходить усе, що вже треба публікувати, але НЕ пушить у соцмережі.
    Реальний publish підключимо окремими OAuth-патчами.
    """
    now = datetime.now().isoformat(timespec="seconds")

    con = sqlite3.connect(DB_PATH)
    con.row_factory = sqlite3.Row
    cur = con.cursor()

    due = cur.execute("""
        SELECT *
        FROM scheduled_posts
        WHERE status='scheduled'
          AND scheduled_at <= ?
        ORDER BY scheduled_at ASC
        LIMIT 50
    """, (now,)).fetchall()

    con.close()

    return {
        "status": "ok",
        "mode": "dry_run",
        "due_count": len(due),
        "due": [dict(r) for r in due],
        "next": "Наступний патч: реальний publisher для YouTube/Meta/TikTok.",
    }

