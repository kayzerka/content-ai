@app.post("/posts/add")
def add_post(
    platform: str,
    url: str = "",
    text: str = "",
    views: int = 0,
    likes: int = 0,
    comments: int = 0,
    saves: int = 0,
    shares: int = 0,
    analyze_ai: bool = True,
):
    score = calc_score(views, likes, comments, saves, shares)

    if analyze_ai and text.strip():
        prompt = f"""
Ти AI-контент директор для експерта-регресолога/кармолога.

Проаналізуй конкретний ролик.

Платформа: {platform}
URL: {url}

Опис / текст ролика:
{text}

Метрики:
views={views}
likes={likes}
comments={comments}
saves={saves}
shares={shares}
score={score}

Дай відповідь українською:

1. Тип контенту
2. Головний біль аудиторії
3. Хук: сильний чи слабкий
4. Чому ролик міг спрацювати або не спрацювати
5. Що покращити
6. Який CTA додати
7. Як цей ролик використати у воронці
8. 3 нові ідеї роликів на основі цього
"""
        analysis = run_llm(prompt)
    else:
        analysis = "AI analysis не запускався: немає тексту/опису або analyze_ai=false."

    con = sqlite3.connect(DB_PATH)
    cur = con.cursor()
    cur.execute("""
        INSERT INTO posts (
            created_at, platform, url, text,
            views, likes, comments, saves, shares,
            analysis, score
        )
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
    """, (
        datetime.now().isoformat(timespec="seconds"),
        platform, url, text,
        views, likes, comments, saves, shares,
        analysis, score,
    ))
    post_id = cur.lastrowid
    con.commit()
    con.close()

    return {
        "status": "ok",
        "post_id": post_id,
        "score": score,
        "analysis": analysis,
    }


