def youtube_api_key():
    return os.getenv("YOUTUBE_API_KEY", "").strip()


def get_youtube_public_videos(channel_id: str, max_results: int = 10):
    key = youtube_api_key()
    if not key:
        return {"status": "error", "error": "YOUTUBE_API_KEY не встановлений у .env"}

    search = requests.get(
        "https://www.googleapis.com/youtube/v3/search",
        params={
            "key": key,
            "channelId": channel_id,
            "part": "snippet,id",
            "order": "date",
            "maxResults": max_results,
            "type": "video",
        },
        timeout=30,
    ).json()

    if "error" in search:
        return {"status": "error", "step": "search", "response": search}

    video_ids = [
        item["id"]["videoId"]
        for item in search.get("items", [])
        if item.get("id", {}).get("kind") == "youtube#video"
    ]

    if not video_ids:
        return {"status": "ok", "videos": []}

    stats = requests.get(
        "https://www.googleapis.com/youtube/v3/videos",
        params={
            "key": key,
            "id": ",".join(video_ids),
            "part": "snippet,statistics,contentDetails",
        },
        timeout=30,
    ).json()

    if "error" in stats:
        return {"status": "error", "step": "videos", "response": stats}

    return {"status": "ok", "videos": stats.get("items", [])}


