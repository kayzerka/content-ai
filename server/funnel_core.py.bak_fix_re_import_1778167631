def update_funnel(funnel_id: int, patch: Dict[str, Any]):
    init_funnel_db()

    allowed = [
        "name", "status", "source_platform", "source_type", "goal",
        "trigger_type", "trigger_value", "output_type", "output_target",
        "ai_enabled"
    ]

    sets = []
    vals = []

    for k in allowed:
        if k in patch:
            sets.append(f"{k}=?")
            vals.append(patch[k])

    if "config" in patch:
        sets.append("config_json=?")
        vals.append(jdump(patch.get("config") or {}))

    if not sets:
        return get_funnel(funnel_id)

    vals.append(funnel_id)

    con = db()
    con.execute(f"UPDATE funnels SET {', '.join(sets)} WHERE id=?", vals)
    con.commit()
    con.close()

    log_event(funnel_id, None, "funnel_updated", patch)
    return get_funnel(funnel_id)

def upsert_funnel_step(
    funnel_id: int,
    step_order: int,
    step_type: str,
    step_name: str = "",
    config: Optional[Dict[str, Any]] = None,
):
    init_funnel_db()
    config = config or {}

    con = db()
    cur = con.cursor()

    existing = cur.execute("""
        SELECT id FROM funnel_steps
        WHERE funnel_id=? AND step_order=?
    """, (funnel_id, step_order)).fetchone()

    if existing:
        cur.execute("""
            UPDATE funnel_steps
            SET step_type=?, step_name=?, config_json=?
            WHERE funnel_id=? AND step_order=?
        """, (step_type, step_name or "", jdump(config), funnel_id, step_order))
        step_id = existing["id"]
    else:
        cur.execute("""
            INSERT INTO funnel_steps(
                funnel_id, step_order, step_type, step_name, config_json, created_ts
            )
            VALUES (?, ?, ?, ?, ?, ?)
        """, (funnel_id, step_order, step_type, step_name or "", jdump(config), now_ts()))
        step_id = cur.lastrowid

    con.commit()
    con.close()

    log_event(funnel_id, None, "funnel_step_upserted", {
        "step_id": step_id,
        "step_order": step_order,
        "step_type": step_type,
        "step_name": step_name,
        "config": config,
    })

    return get_funnel(funnel_id)

