
import os
import json
import time
import sqlite3
import urllib.request
import urllib.error
import ssl
from typing import Any, Dict, Optional, List

DB_PATH = os.getenv("CONTENT_AI_DB", os.getenv("DB_PATH", "content_ai.sqlite3"))

def now_ts() -> int:
    return int(time.time())

def db():
    con = sqlite3.connect(DB_PATH)
    con.row_factory = sqlite3.Row
    return con

def jdump(x: Any) -> str:
    return json.dumps(x or {}, ensure_ascii=False)

def jload(s: Optional[str], default=None):
    if default is None:
        default = {}
    try:
        return json.loads(s) if s else default
    except Exception:
        return default

def init_funnel_db():
    con = db()
    cur = con.cursor()

    cur.execute("""
    CREATE TABLE IF NOT EXISTS funnels (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT NOT NULL,
        status TEXT DEFAULT 'active',
        source_platform TEXT DEFAULT 'instagram',
        source_type TEXT DEFAULT 'reel',
        goal TEXT DEFAULT 'consultation',
        trigger_type TEXT DEFAULT 'keyword',
        trigger_value TEXT DEFAULT '',
        output_type TEXT DEFAULT 'telegram_bot',
        output_target TEXT DEFAULT '',
        ai_enabled INTEGER DEFAULT 1,
        config_json TEXT DEFAULT '{}',
        created_ts INTEGER
    )
    """)

    cur.execute("""
    CREATE TABLE IF NOT EXISTS funnel_steps (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        funnel_id INTEGER NOT NULL,
        step_order INTEGER NOT NULL,
        step_type TEXT NOT NULL,
        step_name TEXT DEFAULT '',
        config_json TEXT DEFAULT '{}',
        created_ts INTEGER,
        FOREIGN KEY(funnel_id) REFERENCES funnels(id)
    )
    """)

    cur.execute("""
    CREATE TABLE IF NOT EXISTS funnel_contacts (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        funnel_id INTEGER NOT NULL,
        platform TEXT NOT NULL,
        external_user_id TEXT NOT NULL,
        username TEXT DEFAULT '',
        first_seen_ts INTEGER,
        current_step INTEGER DEFAULT 1,
        lead_score REAL DEFAULT 0,
        tags_json TEXT DEFAULT '[]',
        state_json TEXT DEFAULT '{}',
        UNIQUE(funnel_id, platform, external_user_id)
    )
    """)

    cur.execute("""
    CREATE TABLE IF NOT EXISTS funnel_events (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        funnel_id INTEGER,
        contact_id INTEGER,
        event_type TEXT NOT NULL,
        payload_json TEXT DEFAULT '{}',
        created_ts INTEGER
    )
    """)

    cur.execute("""
    CREATE TABLE IF NOT EXISTS funnel_jobs (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        funnel_id INTEGER,
        contact_id INTEGER,
        execute_at INTEGER NOT NULL,
        action_type TEXT NOT NULL,
        payload_json TEXT DEFAULT '{}',
        status TEXT DEFAULT 'pending',
        created_ts INTEGER,
        executed_ts INTEGER
    )
    """)

    con.commit()
    con.close()

def row_to_dict(r):
    return dict(r) if r else None

def log_event(funnel_id, contact_id, event_type, payload=None):
    init_funnel_db()
    con = db()
    con.execute("""
        INSERT INTO funnel_events(funnel_id, contact_id, event_type, payload_json, created_ts)
        VALUES (?, ?, ?, ?, ?)
    """, (funnel_id, contact_id, event_type, jdump(payload), now_ts()))
    con.commit()
    con.close()

def create_default_funnel(name="Instagram → Telegram → Consultation"):
