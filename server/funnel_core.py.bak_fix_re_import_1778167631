def run_contact_next_step(funnel_id: int, platform: str, external_user_id: str):
    init_funnel_db()

    contact = get_contact_by_external(funnel_id, platform, external_user_id)
    if not contact:
        return {
            "ok": False,
            "error": "contact_not_found",
            "hint": "First send /api/funnels/event for this user"
        }

    step_order = int(contact.get("current_step") or 1)
    step = get_step(funnel_id, step_order)

    if not step:
        return {
            "ok": True,
            "done": True,
            "contact": contact,
            "message": "No more steps"
        }

    result = execute_step(contact, step)

    return {
        "ok": result.get("ok", False),
        "done": False,
        "contact": contact,
        "step": step,
        "result": result,
    }

