def list_funnels():
    init_funnel_db()
    con = db()
    rows = con.execute("SELECT * FROM funnels ORDER BY id DESC").fetchall()
    con.close()
    return [row_to_dict(r) for r in rows]

def get_funnel(funnel_id: int):
    init_funnel_db()
    con = db()
    f = con.execute("SELECT * FROM funnels WHERE id=?", (funnel_id,)).fetchone()
    steps = con.execute("""
        SELECT * FROM funnel_steps WHERE funnel_id=? ORDER BY step_order ASC
    """, (funnel_id,)).fetchall()
    con.close()
    out = row_to_dict(f)
    if not out:
        return None
    out["config"] = jload(out.pop("config_json", "{}"))
    out["steps"] = []
    for s in steps:
        d = row_to_dict(s)
        d["config"] = jload(d.pop("config_json", "{}"))
        out["steps"].append(d)
    return out

def create_or_get_contact(funnel_id: int, platform: str, external_user_id: str, username: str = ""):
    init_funnel_db()
    con = db()
    cur = con.cursor()

    cur.execute("""
        INSERT OR IGNORE INTO funnel_contacts(
            funnel_id, platform, external_user_id, username,
            first_seen_ts, current_step, lead_score, tags_json, state_json
        )
        VALUES (?, ?, ?, ?, ?, 1, 0, '[]', '{}')
    """, (funnel_id, platform, external_user_id, username or "", now_ts()))

    con.commit()

    row = cur.execute("""
        SELECT * FROM funnel_contacts
        WHERE funnel_id=? AND platform=? AND external_user_id=?
    """, (funnel_id, platform, external_user_id)).fetchone()

    con.close()
    return row_to_dict(row)

def get_step(funnel_id: int, step_order: int):
    init_funnel_db()
    con = db()
    row = con.execute("""
        SELECT * FROM funnel_steps
        WHERE funnel_id=? AND step_order=?
    """, (funnel_id, step_order)).fetchone()
    con.close()

    d = row_to_dict(row)
    if d:
        d["config"] = jload(d.pop("config_json", "{}"))
    return d

def advance_contact(contact_id: int, next_step: int):
    init_funnel_db()
    con = db()
    con.execute("UPDATE funnel_contacts SET current_step=? WHERE id=?", (next_step, contact_id))
    con.commit()
    con.close()

def enqueue_job(funnel_id: int, contact_id: int, execute_at: int, action_type: str, payload: Dict[str, Any]):
    init_funnel_db()
    con = db()
    con.execute("""
        INSERT INTO funnel_jobs(funnel_id, contact_id, execute_at, action_type, payload_json, status, created_ts)
        VALUES (?, ?, ?, ?, ?, 'pending', ?)
    """, (funnel_id, contact_id, execute_at, action_type, jdump(payload), now_ts()))
    con.commit()
    con.close()



def get_contact_state(contact: Dict[str, Any]) -> Dict[str, Any]:
    return jload(contact.get("state_json"), {})

def update_contact_state(contact_id: int, patch: Dict[str, Any]):
    init_funnel_db()
    con = db()
    row = con.execute("SELECT state_json FROM funnel_contacts WHERE id=?", (contact_id,)).fetchone()
    state = jload(row["state_json"] if row else "{}", {})
    state.update(patch or {})
    con.execute("UPDATE funnel_contacts SET state_json=? WHERE id=?", (jdump(state), contact_id))
    con.commit()
    con.close()
    return state

def bind_contact_telegram_chat(
    funnel_id: int,
    platform: str,
    external_user_id: str,
    telegram_chat_id: str,
    username: str = "",
):
    init_funnel_db()
    contact = create_or_get_contact(funnel_id, platform, external_user_id, username or "")
    state = update_contact_state(contact["id"], {
        "telegram_chat_id": str(telegram_chat_id),
        "telegram_bound_ts": now_ts(),
    })
    log_event(funnel_id, contact["id"], "telegram_chat_bound", {
        "telegram_chat_id": str(telegram_chat_id),
    })
    contact["state_json"] = jdump(state)
    return contact


def build_telegram_start_payload(funnel_id: int, external_user_id: str) -> str:
    safe_uid = str(external_user_id).replace(" ", "_")
    return f"funnel_{int(funnel_id)}__{safe_uid}"

def build_telegram_start_link(bot_username: Optional[str], funnel_id: int, external_user_id: str) -> str:
    bot_username = (bot_username or os.getenv("TELEGRAM_BOT_USERNAME", "content_ai_planner_bot")).lstrip("@")
    payload = build_telegram_start_payload(funnel_id, external_user_id)
    return f"https://t.me/{bot_username}?start={payload}"

def parse_telegram_start_payload(payload: str) -> Dict[str, Any]:
    """
    Expected: funnel_1__external_user_id
    """
    payload = (payload or "").strip()
    m = re.match(r"^funnel_(\\d+)__(.+)$", payload)
    if not m:
        return {"ok": False, "error": "bad_start_payload", "payload": payload}

    return {
        "ok": True,
        "funnel_id": int(m.group(1)),
        "external_user_id": m.group(2),
        "payload": payload,
    }

def handle_telegram_start_update(update: Dict[str, Any]) -> Dict[str, Any]:
    """
    Accepts raw Telegram update JSON item.
    Binds chat_id to funnel contact when text is:
    /start funnel_1__some_external_user_id
    """
    msg = update.get("message") or update.get("edited_message") or {}
    text = (msg.get("text") or "").strip()
    chat = msg.get("chat") or {}
    tg_user = msg.get("from") or {}

    if not text.startswith("/start"):
        return {"ok": False, "skipped": True, "reason": "not_start"}

    parts = text.split(maxsplit=1)
    payload = parts[1].strip() if len(parts) > 1 else ""

    parsed = parse_telegram_start_payload(payload)
    if not parsed.get("ok"):
        return parsed

    chat_id = chat.get("id")
    if not chat_id:
        return {"ok": False, "error": "chat_id_missing"}

    username = (
        tg_user.get("username")
        or chat.get("username")
        or tg_user.get("first_name")
        or ""
    )

    contact = bind_contact_telegram_chat(
        funnel_id=parsed["funnel_id"],
        platform="instagram",
        external_user_id=parsed["external_user_id"],
        telegram_chat_id=str(chat_id),
        username=username,
    )

    welcome = (
        "Готово, я підключила Telegram до твоєї заявки ❤️\\n"
        "Тепер можу надіслати матеріал і мʼяко провести далі."
    )

    tg_send = send_telegram_message(str(chat_id), welcome)

    return {
        "ok": True,
        "action": "telegram_start_bound",
        "funnel_id": parsed["funnel_id"],
        "external_user_id": parsed["external_user_id"],
        "telegram_chat_id": str(chat_id),
        "contact": contact,
        "telegram": tg_send,
    }


def send_telegram_message(chat_id: str, text: str, parse_mode: Optional[str] = None) -> Dict[str, Any]:
    token = os.getenv("TELEGRAM_BOT_TOKEN", "").strip()
    if not token:
        return {
            "ok": False,
            "error": "TELEGRAM_BOT_TOKEN_missing",
        }

    if not chat_id:
        return {
            "ok": False,
            "error": "telegram_chat_id_missing",
        }

    if not text:
        return {
            "ok": False,
            "error": "telegram_text_empty",
        }

    payload = {
        "chat_id": str(chat_id),
        "text": text,
        "disable_web_page_preview": False,
    }

    if parse_mode:
        payload["parse_mode"] = parse_mode

    try:
        req = urllib.request.Request(
            f"https://api.telegram.org/bot{token}/sendMessage",
            data=json.dumps(payload, ensure_ascii=False).encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="POST",
        )

        with urllib.request.urlopen(
            req,
            timeout=25,
            context=ssl._create_unverified_context() if os.getenv("TELEGRAM_SSL_VERIFY", "0") != "1" else None,
        ) as resp:
            raw = resp.read().decode("utf-8", errors="replace")
            data = json.loads(raw)
            return {
                "ok": bool(data.get("ok")),
                "provider": "telegram",
                "response": data,
            }

    except Exception as e:
        return {
            "ok": False,
            "provider": "telegram",
            "error": str(e),
        }

def maybe_deliver_telegram(contact: Dict[str, Any], text: str, cfg: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
    cfg = cfg or {}
    state = get_contact_state(contact)

    chat_id = (
        cfg.get("telegram_chat_id")
        or state.get("telegram_chat_id")
        or state.get("chat_id")
    )

    if not chat_id:
        return {
            "ok": False,
            "skipped": True,
            "reason": "telegram_chat_id_missing",
        }

    parse_mode = cfg.get("parse_mode") or None
    return send_telegram_message(str(chat_id), text, parse_mode=parse_mode)


def generate_funnel_ai_text(contact: Dict[str, Any], prompt: str, cfg: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
    """
    MVP AI generator:
    - tries DeepSeek-compatible chat endpoint if DEEPSEEK_API_KEY exists
    - falls back to deterministic local text
    """
    cfg = cfg or {}
    api_key = os.getenv("DEEPSEEK_API_KEY", "").strip()
    api_base = os.getenv("DEEPSEEK_API_BASE", "https://api.deepseek.com").rstrip("/")
    model = os.getenv("DEEPSEEK_MODEL", "deepseek-chat")

    state = jload(contact.get("state_json"), {})
    tags = jload(contact.get("tags_json"), [])

    system = cfg.get("system") or (
        "Ти мʼякий Telegram/Instagram sales assistant для експертної консультації. "
        "Пиши українською. Не тисни. Не обіцяй медичних результатів. "
        "1 повідомлення, коротко, тепло, з одним питанням."
    )

    user = (
        f"Згенеруй повідомлення для ліда у воронці.\n"
        f"platform={contact.get('platform')}\n"
        f"username={contact.get('username')}\n"
        f"state={json.dumps(state, ensure_ascii=False)}\n"
        f"tags={json.dumps(tags, ensure_ascii=False)}\n"
        f"Завдання: {prompt}\n"
    )

    if api_key:
        try:
            payload = {
                "model": model,
                "messages": [
                    {"role": "system", "content": system},
                    {"role": "user", "content": user},
                ],
                "temperature": float(cfg.get("temperature", 0.7)),
                "max_tokens": int(cfg.get("max_tokens", 220)),
            }

            req = urllib.request.Request(
                api_base + "/chat/completions",
                data=json.dumps(payload, ensure_ascii=False).encode("utf-8"),
                headers={
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + api_key,
                },
                method="POST",
            )

            with urllib.request.urlopen(
                req,
                timeout=int(cfg.get("timeout", 35)),
                context=ssl._create_unverified_context() if os.getenv("FUNNEL_AI_SSL_VERIFY", "0") != "1" else None,
            ) as resp:
                raw = resp.read().decode("utf-8", errors="replace")
                data = json.loads(raw)
                text = (
                    data.get("choices", [{}])[0]
                    .get("message", {})
                    .get("content", "")
                    .strip()
                )

                if text:
                    return {
                        "ok": True,
                        "provider": "deepseek",
                        "model": model,
                        "text": text,
                        "raw": data,
                    }

        except Exception as e:
            return {
                "ok": False,
                "provider": "deepseek",
                "error": str(e),
                "text": (
                    "Бачу, що ця тема тобі відгукнулась ❤️ "
                    "Що саме зараз найбільше хочеться змінити у своїй ситуації?"
                ),
            }

    return {
        "ok": True,
        "provider": "fallback",
        "model": "local_template",
        "text": (
            "Бачу, що ця тема тобі відгукнулась ❤️ "
            "Що саме зараз найбільше хочеться змінити у своїй ситуації?"
        ),
    }


def execute_step(contact: Dict[str, Any], step: Dict[str, Any]):
    funnel_id = contact["funnel_id"]
    contact_id = contact["id"]
    step_type = step["step_type"]
    cfg = step.get("config") or {}

    result = {
        "ok": True,
        "step_type": step_type,
        "step_order": step["step_order"],
        "action": None,
        "message": None,
        "payload": cfg,
    }

    if step_type in ("send_message", "send_dm", "send_telegram_invite", "send_free_gift", "send_cta"):
        base_text = cfg.get("text") or cfg.get("title") or ""
        url = cfg.get("url") or ""

        if step_type == "send_telegram_invite" and not url:
            url = build_telegram_start_link(
                cfg.get("bot_username") or None,
                funnel_id,
                contact.get("external_user_id") or contact_id,
            )

        text = (base_text + ("\n" + url if url else "")).strip()

        result["action"] = "message_ready"
        result["message"] = text

        delivery = cfg.get("delivery") or cfg.get("send_via") or ""
        tg_result = None

        if delivery == "telegram":
            tg_result = maybe_deliver_telegram(contact, text, cfg)
            result["telegram"] = tg_result
            result["action"] = "telegram_sent" if tg_result.get("ok") else "telegram_error"

        log_event(funnel_id, contact_id, f"step_{step_type}", {
            "step_order": step["step_order"],
            "config": cfg,
            "message": text,
            "telegram": tg_result,
        })

        if tg_result:
            log_event(
                funnel_id,
                contact_id,
                "telegram_sent" if tg_result.get("ok") else "telegram_error",
                {
                    "step_order": step["step_order"],
                    "step_type": step_type,
                    "message": text,
                    "telegram": tg_result,
                }
            )

        advance_contact(contact_id, step["step_order"] + 1)
        return result

    if step_type == "send_ai_message":
        prompt = cfg.get("prompt", "")
        gen = generate_funnel_ai_text(contact, prompt, cfg)

        result["action"] = "ai_message_generated"
        result["message"] = gen.get("text", "")
        result["generated"] = {
            "ok": gen.get("ok"),
            "provider": gen.get("provider"),
            "model": gen.get("model"),
            "error": gen.get("error"),
        }

        tg_result = None
        auto_send = int(cfg.get("auto_send", 1))
        delivery = cfg.get("delivery") or cfg.get("send_via") or "telegram"

        if auto_send and delivery == "telegram":
            tg_result = maybe_deliver_telegram(contact, result["message"], cfg)
            result["telegram"] = tg_result
            if tg_result.get("ok"):
                result["action"] = "ai_message_generated_and_telegram_sent"
            elif not tg_result.get("skipped"):
                result["action"] = "ai_message_generated_telegram_error"

        log_event(funnel_id, contact_id, "step_send_ai_message", {
            "step_order": step["step_order"],
            "prompt": prompt,
            "generated_text": result["message"],
            "provider": gen.get("provider"),
            "model": gen.get("model"),
            "ok": gen.get("ok"),
            "error": gen.get("error"),
            "telegram": tg_result,
        })

        if tg_result:
            log_event(
                funnel_id,
                contact_id,
                "telegram_sent" if tg_result.get("ok") else "telegram_error",
                {
                    "step_order": step["step_order"],
                    "step_type": step_type,
                    "message": result["message"],
                    "telegram": tg_result,
                }
            )

        advance_contact(contact_id, step["step_order"] + 1)
        return result

    if step_type == "wait_delay":
        delay = int(cfg.get("delay_seconds") or 3600)
        next_step = step["step_order"] + 1

        enqueue_job(funnel_id, contact_id, now_ts() + delay, "continue_funnel", {
            "next_step": next_step,
            "from_step": step["step_order"],
        })

        log_event(funnel_id, contact_id, "step_wait_delay", {
            "delay_seconds": delay,
            "next_step": next_step,
        })

        advance_contact(contact_id, next_step)
        result["action"] = "job_scheduled"
        result["message"] = f"Scheduled next step in {delay} seconds"
        return result

    result["ok"] = False
    result["action"] = "unknown_step"
    result["message"] = f"Unknown step_type={step_type}"
    return result

def process_funnel_event(
    funnel_id: int,
    platform: str,
    external_user_id: str,
    event_type: str,
    payload: Optional[Dict[str, Any]] = None,
    username: str = "",
):
    init_funnel_db()
    payload = payload or {}

    contact = create_or_get_contact(funnel_id, platform, external_user_id, username)
    log_event(funnel_id, contact["id"], event_type, payload)

    step_order = int(contact.get("current_step") or 1)
    step = get_step(funnel_id, step_order)

    if not step:
        return {
            "ok": True,
            "done": True,
            "message": "No more steps",
            "contact": contact,
        }

    result = execute_step(contact, step)
    return {
        "ok": result.get("ok", False),
        "done": False,
        "contact": contact,
        "step": step,
        "result": result,
    }

def pending_jobs(limit: int = 50):
    init_funnel_db()
    con = db()
    rows = con.execute("""
        SELECT * FROM funnel_jobs
        WHERE status='pending' AND execute_at <= ?
        ORDER BY execute_at ASC
        LIMIT ?
    """, (now_ts(), limit)).fetchall()
    con.close()
    return [row_to_dict(r) for r in rows]

def run_due_jobs(limit: int = 50):
    init_funnel_db()
    jobs = pending_jobs(limit)
    results = []

    for job in jobs:
        payload = jload(job.get("payload_json"), {})
        contact_id = job["contact_id"]

        con = db()
        contact = con.execute("SELECT * FROM funnel_contacts WHERE id=?", (contact_id,)).fetchone()
        con.close()

        if not contact:
            continue

        contact = row_to_dict(contact)
        next_step = int(payload.get("next_step") or contact.get("current_step") or 1)
        step = get_step(contact["funnel_id"], next_step)

        if step:
            res = execute_step(contact, step)
        else:
            res = {"ok": True, "done": True, "message": "No step found"}

        con = db()
        con.execute("""
            UPDATE funnel_jobs
            SET status='done', executed_ts=?
            WHERE id=?
        """, (now_ts(), job["id"]))
        con.commit()
        con.close()

        results.append({
            "job": job,
            "result": res,
        })

    return results

def funnel_stats():
    init_funnel_db()
    con = db()
    rows = con.execute("""
        SELECT
            f.id,
            f.name,
            f.status,
            COUNT(DISTINCT c.id) AS contacts,
            COUNT(e.id) AS events,
            SUM(CASE WHEN e.event_type LIKE 'step_%' THEN 1 ELSE 0 END) AS steps_executed
        FROM funnels f
        LEFT JOIN funnel_contacts c ON c.funnel_id = f.id
        LEFT JOIN funnel_events e ON e.funnel_id = f.id
        GROUP BY f.id
        ORDER BY f.id DESC
    """).fetchall()
    con.close()
    return [row_to_dict(r) for r in rows]


